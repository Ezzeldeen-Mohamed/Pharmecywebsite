@model ServiceRequest
@using ePharma_asp_mvc.Models.Enums

<div class="container py-5">
    <div class="card shadow border-0">
        <div class="card-header bg-dark text-white d-flex justify-content-between">
            <h4 class="mb-0">Request Details #@Model.Id</h4>
            <span class="badge @(Model.Status == ServiceRequestStatus.Pending ? "bg-warning" : "bg-success")">
                @Model.Status.ToString()
            </span>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <h5>Customer Information</h5>
                    <p><strong>Name:</strong> @Model.User.FirstName @Model.User.LastName</p>
                    <p><strong>Phone:</strong> @Model.ContactPhoneNumber</p>
                    <p><strong>Address:</strong> @Model.Address</p>
                </div>
                <div class="col-md-6">
                    <h5>Service Information</h5>
                    <p><strong>Service:</strong> @Model.Service.Name</p>
                    <p><strong>Price:</strong> $@Model.PriceAtTimeOfRequest</p>
                    <p><strong>Date:</strong> @Model.RequestTime.ToString("f")</p>
                    <p><strong>Notes:</strong> @(Model.Notes ?? "No notes provided.")</p>
                </div>
            </div>

            <hr />

            <div class="d-flex gap-2">
                @if (User.IsInRole("Admin") || User.IsInRole("Pharmacist"))
                {
                    <!-- أزرار الصيدلي للأكشن السريع -->
                    <form asp-action="ChangeStatus" method="post">
                        <input type="hidden" name="id" value="@Model.Id" />
                        @if (Model.Status == ServiceRequestStatus.Pending)
                        {
                            <button name="status" value="@ServiceRequestStatus.Accepted" class="btn btn-primary">Accept Request</button>
                        }
                        else if (Model.Status == ServiceRequestStatus.Accepted)
                        {
                            <button name="status" value="@ServiceRequestStatus.Completed" class="btn btn-success">Mark Completed</button>
                        }
                    </form>

                    <form asp-action="DeleteRequest" method="post" onsubmit="return confirm('Are you sure?')">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-danger">Delete Request</button>
                    </form>
                }
                else
                {
                    <!-- أزرار المستخدم -->
                    @if (Model.Status == ServiceRequestStatus.Pending)
                    {
                        <form asp-action="CancelRequest" method="post">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-outline-danger">Cancel My Request</button>
                        </form>
                    }
                }
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </div>
    </div>
</div>