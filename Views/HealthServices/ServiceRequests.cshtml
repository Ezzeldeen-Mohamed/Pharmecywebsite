@using ePharma_asp_mvc.Models.Enums
@model IEnumerable<ServiceRequest>

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2 class="text-dark">
            <i class="fas fa-notes-medical me-2"></i>
            Service Requests
        </h2>

    </div>

    <div class="card shadow border-0">

        <div class="card-body p-0">

            <table class="table table-hover mb-0">

                <thead class="bg-primary text-white">

                    <tr>
                        <th>Request ID</th>
                        <th>Customer</th>
                        <th>Service</th>
                        <th>Phone</th>
                        <th>Address</th>
                        <th>Date</th>
                        <th>Status</th>
                    </tr>

                </thead>

                <tbody>

                    @if (Model.Any())
                    {
                        @foreach (var request in Model)
                        {
                            <tr onclick="location.href='@Url.Action("Details", "HealthServices", new { id = request.Id })'"style="cursor: pointer;">
                                <td>
                                    #@request.Id
                                </td>

                                <td>
                                    @request.User.FirstName
                                    @request.User.LastName
                                </td>

                                <td>
                                    @request.Service.Name
                                </td>

                                <td>
                                    @request.ContactPhoneNumber
                                </td>

                                <td>
                                    @request.Address
                                </td>

                                <td>
                                    @request.RequestTime.ToString("dd/MM/yyyy HH:mm")
                                </td>


                                <td>
                                    @if (request.Status == ServiceRequestStatus.Pending)
                                    {
                                        <span class="badge bg-warning text-dark">Pending</span>
                                    }
                                    else if (request.Status == ServiceRequestStatus.Accepted)
                                    {
                                        <span class="badge bg-info text-white">Accepted</span>
                                    }
                                    else if (request.Status == ServiceRequestStatus.Completed)
                                    {
                                        <span class="badge bg-success text-white">Completed</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger text-white">Cancelled</span>
                                    }
                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>

                            <td colspan="7" class="text-center py-4">

                                <div class="alert alert-info mb-0">
                                    No service requests found.
                                </div>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>