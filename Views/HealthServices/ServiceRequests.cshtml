@using ePharma_asp_mvc.Models.Enums
@model IEnumerable<ServiceRequest>

@{
    ViewData["Title"] = "لوحة التحكم بطلبات الرعاية الصحية";
}

<div class="container py-5" dir="rtl">
    <div class="d-flex justify-content-between align-items-center mb-4 text-right">
        <h2 class="text-dark fw-bold mb-0">
            <i class="fas fa-notes-medical text-primary ml-2"></i> لوحة إدارة طلبات الرعاية والخدمات الصحية
        </h2>
    </div>

    <div class="card shadow-sm border-0 signup-container bg-white">
        <div class="card-body p-0 text-right">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-primary text-white">
                        <tr>
                            <th class="p-3">رقم الطلب</th>
                            <th class="p-3">العميل</th>
                            <th class="p-3">الخدمة المطلوبة</th>
                            <th class="p-3">الهاتف</th>
                            <th class="p-3">العنوان</th>
                            <th class="p-3">التوقيت والتاريخ</th>
                            <th class="p-3 text-center">حالة الطلب الحالي</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            @foreach (var request in Model)
                            {
                                <tr onclick="location.href='@Url.Action("Details", "HealthServices", new { id = request.Id })'"
                                    style="cursor: pointer;"
                                    class="clickable-row-custom">

                                    <td class="p-3 fw-bold text-secondary">#@request.Id</td>
                                    <td class="p-3 fw-bold text-dark">@request.User.FirstName @request.User.LastName</td>
                                    <td class="p-3 text-primary fw-bold">@request.Service.Name</td>
                                    <td class="p-3" dir="ltr">@request.ContactPhoneNumber</td>
                                    <td class="p-3 text-truncate-custom">@request.Address</td>
                                    <td class="p-3 text-muted small">@request.RequestTime.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="p-3 text-center">
                                        @if (request.Status == ServiceRequestStatus.Pending)
                                        {
                                            <span class="badge bg-warning text-dark px-2 py-2 rounded"><i class="fas fa-spinner fa-spin ml-1"></i>قيد الانتظار</span>
                                        }
                                        else if (request.Status == ServiceRequestStatus.Accepted)
                                        {
                                            <span class="badge bg-info text-white px-2 py-2 rounded"><i class="fas fa-thumbs-up ml-1"></i>مقبول</span>
                                        }
                                        else if (request.Status == ServiceRequestStatus.Completed)
                                        {
                                            <span class="badge bg-success text-white px-2 py-2 rounded"><i class="fas fa-check-double ml-1"></i>مكتمل</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger text-white px-2 py-2 rounded"><i class="fas fa-times ml-1"></i>ملغي</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5">
                                    <div class="alert alert-warning border-0 shadow-sm d-inline-block px-5 mb-0">
                                        <i class="fas fa-exclamation-triangle ml-2"></i> لا توجد طلبات واردة في النظام حالياً للخدمات الصحية.
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .signup-container {
        border-radius: 16px !important;
        overflow: hidden;
        border: 1px solid rgba(0, 0, 0, 0.05) !important;
    }

    .clickable-row-custom:hover {
        background-color: #f4f6f9 !important;
    }

    .text-truncate-custom {
        max-width: 150px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
</style>