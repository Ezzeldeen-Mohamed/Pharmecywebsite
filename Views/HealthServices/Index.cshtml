@model IEnumerable<HealthService>

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="text-primary mb-0">
                <i class="fas fa-heartbeat me-2"></i>
                Health Services
            </h2>
            <p class="text-muted mb-0">Choose the healthcare service you need.</p>
        </div>

        <!-- زرار عرض طلباتي -->
        <a asp-action="MyRequests" class="btn btn-outline-primary shadow-sm">
            <i class="fas fa-list-ul me-2"></i>
            My Previous Requests
        </a>
    </div>


    <div class="row">

        @foreach (var service in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">

                <div class="card shadow border-0 h-100">

                    <div class="card-body text-center">

                        <h4 class="text-dark mb-3">
                            @service.Name
                        </h4>

                        <p class="text-muted">
                            @service.Description
                        </p>

                        <h5 class="text-success mb-4">
                            $@service.Price
                        </h5>

                        <a asp-action="RequestService"
                           asp-route-serviceId="@service.Id"
                           class="btn btn-primary px-4">
                            Request Service
                        </a>

                    </div>

                </div>

            </div>
        }

    </div>

</div>