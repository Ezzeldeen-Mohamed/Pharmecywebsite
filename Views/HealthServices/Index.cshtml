@model IEnumerable<HealthService>

@{
    ViewData["Title"] = "الخدمات الطبية المنزلية";
}

<div class="container py-5" dir="rtl">
    <!-- الهيدر وقسم التوجيه للطلبات السابقة -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5 text-right">
        <div class="mb-3 mb-md-0">
            <h2 class="text-primary mb-1 fw-bold">
                <i class="fas fa-heartbeat text-danger animation-pulse ml-2"></i> الرعاية والخدمات الطبية
            </h2>
            <p class="text-muted mb-0">اختر الخدمة الطبية أو المنزلية التي ترغب في توفيرها بأعلى جودة.</p>
        </div>

        <a asp-action="MyRequests" class="btn btn-outline-primary shadow-sm rounded-pill px-4 py-2 fw-bold">
            <i class="fas fa-notes-medical ml-2"></i> سجل طلباتي السابقة
        </a>
    </div>

    <!-- شبكة عرض الخدمات المتاحة -->
    <div class="row text-right">
        @foreach (var service in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card service-card shadow-sm border-0 h-100 rounded-3 text-center p-3 bg-white">
                    <div class="card-body d-flex flex-column justify-content-between">
                        <div>
                            <div class="icon-box bg-light-primary text-primary mx-auto mb-3 rounded-circle d-flex align-items-center justify-content-center">
                                <i class="fas fa-stethoscope fa-2x"></i>
                            </div>
                            <h4 class="text-dark fw-bold mb-3">@service.Name</h4>
                            <p class="text-muted small px-2 mb-4">@service.Description</p>
                        </div>

                        <div>
                            <h5 class="text-success fw-bold mb-4 bg-light py-2 rounded-3">@service.Price$</h5>
                            <a asp-action="RequestService" asp-route-serviceId="@service.Id" class="btn btn-primary w-100 py-2 rounded-pill fw-bold shadow-sm">
                                <i class="fas fa-plus shadow-sm ml-1"></i> طلب الخدمة الآن
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .service-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border: 1px solid rgba(0,0,0,0.03) !important;
    }

        .service-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,123,255,0.1) !important;
        }

    .icon-box {
        width: 70px;
        height: 70px;
    }

    .bg-light-primary {
        background-color: #f0f7ff;
    }

    .animation-pulse {
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.1);
        }

        100% {
            transform: scale(1);
        }
    }
</style>