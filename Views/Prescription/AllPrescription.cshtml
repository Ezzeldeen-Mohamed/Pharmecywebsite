@using ePharma_asp_mvc.Models.Enums
@model IEnumerable<Prescription>

@{
    ViewData["Title"] = User.IsInRole("Admin") ? "إدارة الروشتات" : "روشتاتي";
}

<style>

    body {
        background: #f5f7fb;
    }

    .pres-page {
        direction: rtl;
    }

    .page-header {
        margin-bottom: 25px;
    }

    .page-title {
        font-weight: 800;
        color: #212529;
    }

    .page-desc {
        color: #6c757d;
        font-size: 14px;
    }

    .card-modern {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,.08);
        border: none;
        overflow: hidden;
    }

    .table th {
        font-size: 13px;
        color: #666;
        font-weight: 600;
        white-space: nowrap;
    }

    .table td {
        vertical-align: middle;
    }

    .pres-img {
        width: 60px;
        height: 60px;
        object-fit: cover;
        border-radius: 12px;
        border: 1px solid #eee;
    }

    .badge-status {
        padding: 8px 14px;
        border-radius: 30px;
        font-size: 12px;
        font-weight: 600;
        display: inline-block;
        min-width: 90px;
        text-align: center;
    }

    .btn-icon {
        border-radius: 10px;
        padding: 6px 10px;
    }

    .btn-group .btn {
        margin: 0 2px;
    }

    .empty-box {
        padding: 60px 20px;
        text-align: center;
    }

    .empty-box i {
        font-size: 60px;
        color: #adb5bd;
        margin-bottom: 15px;
    }

    .upload-btn {
        border-radius: 12px;
        padding: 10px 18px;
        font-weight: 600;
    }

    .alert-modern {
        border-radius: 14px;
    }

    @@media(max-width:768px) {

        .table {
            min-width: 800px;
        }

        .page-title {
            font-size: 20px;
        }
    }

</style>

<div class="pres-page">

    <div class="container mt-5">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center flex-wrap page-header">

            <div>
                <h2 class="page-title">
                    @(User.IsInRole("Admin") ? "طلبات الروشتات" : "روشتاتي")
                </h2>

                <p class="page-desc">
                    @(User.IsInRole("Admin")
                        ? "إدارة ومراجعة طلبات الروشتات من المستخدمين"
                        : "متابعة حالة الروشتات التي قمت برفعها")
                </p>
            </div>

            @if (!User.IsInRole("Admin"))
            {
                <a asp-action="Upload"
                   asp-controller="Prescription"
                   class="btn btn-primary upload-btn">

                    رفع روشتة جديدة

                </a>
            }

        </div>

        <!-- Success Alert -->
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-modern alert-dismissible fade show">
                <i class="fas fa-check-circle me-2"></i>
                @TempData["Success"]

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="alert"></button>
            </div>
        }

        <!-- Card -->
        <div class="card-modern">

            <div class="table-responsive">

                <table class="table table-hover mb-0">

                    <thead class="table-light">

                        <tr>
                            <th>الصورة</th>

                            @if (User.IsInRole("Admin"))
                            {
                                <th>المستخدم</th>
                            }

                            <th>التواصل</th>
                            <th>الملاحظات</th>
                            <th>الحالة</th>
                            <th>التاريخ</th>
                            <th class="text-center">الإجراءات</th>
                        </tr>

                    </thead>

                    <tbody>

                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="7">
                                    <div class="empty-box">

                                        <i class="fas fa-folder-open"></i>

                                        <h5>لا توجد روشتات</h5>

                                        <p class="text-muted">
                                            لم يتم رفع أي روشتة حتى الآن
                                        </p>

                                    </div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model)
                            {
                                var badgeClass = item.Status switch
                                {
                                    PrescriptionStatus.Pending => "bg-warning text-dark",
                                    PrescriptionStatus.Accepted => "bg-info text-white",
                                    PrescriptionStatus.Completed => "bg-success text-white",
                                    PrescriptionStatus.Cancelled => "bg-danger text-white",
                                    _ => "bg-secondary text-white"
                                };

                                <tr>

                                    <!-- Image -->
                                    <td>
                                        <img src="@Url.Content(item.ImagePath)"
                                             class="pres-img" />
                                    </td>

                                    <!-- User -->
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <td>
                                            <strong>
                                                @(item.User?.UserName ?? "مستخدم")
                                            </strong>
                                            <br />
                                            <small class="text-muted">
                                                @(item.User?.Email ?? "")
                                            </small>
                                        </td>
                                    }

                                    <!-- Contact -->
                                    <td>
                                        <div class="small">
                                            📞 @item.PhoneNumber
                                        </div>

                                        <div class="text-muted small">
                                            📍 @item.Address
                                        </div>
                                    </td>

                                    <!-- Notes -->
                                    <td>
                                        @(string.IsNullOrEmpty(item.Notes)
                                            ? "لا توجد ملاحظات"
                                            : item.Notes)
                                    </td>

                                    <!-- Status -->
                                    <td>
                                        <span class="badge-status @badgeClass">
                                            @switch (item.Status)
                                            {
                                                case PrescriptionStatus.Pending:
                                                    @:قيد المراجعة
                                                    break;

                                                case PrescriptionStatus.Accepted:
                                                    @:تم القبول
                                                    break;

                                                case PrescriptionStatus.Completed:
                                                    @:مكتمل
                                                    break;

                                                case PrescriptionStatus.Cancelled:
                                                    @:ملغي
                                                    break;
                                            }
                                        </span>
                                    </td>

                                    <!-- Date -->
                                    <td class="text-muted small">
                                        @item.CreatedAt.ToString("dd/MM/yyyy hh:mm tt")
                                    </td>

                                    <!-- Actions -->
                                    <td class="text-center">

                                        <div class="btn-group btn-group-sm">

                                            <a asp-action="Details"
                                               asp-controller="Prescription"
                                               asp-route-id="@item.Id"
                                               class="btn btn-outline-secondary btn-icon">
                                                <i class="fas fa-eye"></i>
                                            </a>

                                            @if (User.IsInRole("Admin"))
                                            {
                                                @if (item.Status == PrescriptionStatus.Pending)
                                                {
                                                    <form asp-action="UpdateStatus" method="post" class="d-inline">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@item.Id" />
                                                        <input type="hidden" name="status" value="Accepted" />

                                                        <button class="btn btn-outline-success btn-icon">
                                                            <i class="fas fa-check"></i>
                                                        </button>
                                                    </form>

                                                    <form asp-action="UpdateStatus" method="post" class="d-inline">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@item.Id" />
                                                        <input type="hidden" name="status" value="Cancelled" />

                                                        <button class="btn btn-outline-danger btn-icon">
                                                            <i class="fas fa-times"></i>
                                                        </button>
                                                    </form>
                                                }

                                                <form asp-action="Delete"
                                                      method="post"
                                                      class="d-inline"
                                                      onsubmit="return confirm('هل تريد الحذف نهائياً؟');">

                                                    @Html.AntiForgeryToken()

                                                    <input type="hidden" name="id" value="@item.Id" />

                                                    <button class="btn btn-dark btn-icon">
                                                        <i class="fas fa-trash"></i>
                                                    </button>

                                                </form>
                                            }

                                        </div>

                                    </td>

                                </tr>
                            }
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>