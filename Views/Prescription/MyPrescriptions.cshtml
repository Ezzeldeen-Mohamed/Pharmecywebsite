@model IEnumerable<ePharma_asp_mvc.Models.Prescription>

@{
    ViewData["Title"] = "روشتاتي";
}

<style>

    body {
        background: #f5f7fb;
    }

    .pres-page {
        direction: rtl;
    }

    .page-header {
        margin-bottom: 25px;
    }

    .page-title {
        font-weight: 800;
        color: #212529;
    }

    .upload-btn {
        border-radius: 12px;
        padding: 10px 18px;
        font-weight: 600;
    }

    .pres-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,.08);
        border: none;
        overflow: hidden;
        transition: .3s;
        height: 100%;
    }

        .pres-card:hover {
            transform: translateY(-5px);
        }

    .pres-img {
        width: 100%;
        height: 250px;
        object-fit: cover;
    }

    .pres-body {
        padding: 18px;
        display: flex;
        flex-direction: column;
    }

    .pres-title {
        font-size: 16px;
        font-weight: 700;
        margin-bottom: 5px;
    }

    .pres-date {
        font-size: 13px;
        color: #6c757d;
        margin-bottom: 12px;
    }

    .info-box {
        background: #f8f9fa;
        padding: 10px;
        border-radius: 10px;
        font-size: 13px;
        margin-bottom: 8px;
    }

    .btn-modern {
        border-radius: 12px;
        padding: 10px;
        font-weight: 600;
        margin-top: auto;
    }

    .empty-box {
        background: #fff;
        padding: 60px 20px;
        border-radius: 20px;
        text-align: center;
        box-shadow: 0 10px 30px rgba(0,0,0,.05);
    }

        .empty-box i {
            font-size: 60px;
            color: #adb5bd;
            margin-bottom: 15px;
        }

    @@media(max-width:768px) {
        .page-title {
            font-size: 20px;
        }
    }

</style>

<div class="pres-page">

    <div class="container mt-5">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center flex-wrap page-header">

            <h2 class="page-title">
                روشتاتي
            </h2>

            <a asp-controller="Prescription"
               asp-action="Upload"
               class="btn btn-primary upload-btn">

                رفع روشتة جديدة

            </a>

        </div>

        <!-- Content -->
        @if (Model != null && Model.Any())
        {
            <div class="row">

                @foreach (var item in Model)
                {
                    <div class="col-lg-4 col-md-6 mb-4">

                        <div class="pres-card">

                            <img src="@item.ImagePath"
                                 class="pres-img" />

                            <div class="pres-body">

                                <div class="pres-title">
                                    روشتة رقم #@item.Id
                                </div>

                                <div class="pres-date">
                                    تم الرفع:
                                    @item.CreatedAt.ToString("dd MMM yyyy")
                                </div>

                                @if (!string.IsNullOrEmpty(item.Notes))
                                {
                                    <div class="info-box">
                                        📝 @item.Notes
                                    </div>
                                }

                                @if (!string.IsNullOrEmpty(item.Address))
                                {
                                    <div class="info-box">
                                        📍 @item.Address
                                    </div>
                                }

                                @if (!string.IsNullOrEmpty(item.PhoneNumber))
                                {
                                    <div class="info-box">
                                        📞 @item.PhoneNumber
                                    </div>
                                }

                                <a asp-controller="Prescription"
                                   asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="btn btn-outline-primary btn-modern">

                                    عرض التفاصيل

                                </a>

                            </div>

                        </div>

                    </div>
                }

            </div>
        }
        else
        {
            <div class="empty-box">

                <i class="fas fa-folder-open"></i>

                <h5>لا توجد روشتات</h5>

                <p class="text-muted">
                    لم تقم برفع أي روشتة حتى الآن
                </p>

                <a asp-action="Upload"
                   class="btn btn-primary mt-3">

                    ارفع أول روشتة

                </a>

            </div>
        }

    </div>

</div>