@{
    ViewData["Title"] = "Upload Prescription";
}

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-7">

            <div class="card shadow border-0">

                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">
                        Upload Prescription
                    </h3>
                </div>

                <div class="card-body">

                    <form asp-action="Upload"
                          method="post"
                          enctype="multipart/form-data">

                        @Html.AntiForgeryToken()

                        <div class="form-group mb-4">

                            <label>
                                Prescription Image
                            </label>

                            <input type="file"
                                   name="imageFile"
                                   class="form-control" />

                        </div>

                        <div class="form-group mb-4">

                            <label>
                                Address
                            </label>

                            <input type="text"
                                   name="address"
                                   class="form-control" />

                        </div>

                        <div class="form-group mb-4">

                            <label>
                                Phone Number
                            </label>

                            <input type="text"
                                   name="phoneNumber"
                                   class="form-control" />

                        </div>

                        <div class="form-group mb-4">

                            <label>
                                Notes
                            </label>

                            <textarea name="notes"class="form-control"rows="4"></textarea>

                        </div>

                        <button type="submit"
                                class="btn btn-primary w-100">

                            Upload Prescription

                        </button>

                    </form>

            </div>

        </div>

    </div>

</div>