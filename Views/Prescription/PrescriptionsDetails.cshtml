@model ePharma_asp_mvc.Models.Prescription

@{
    ViewData["Title"] = "تفاصيل الروشتة";
}

<style>

    body {
        background: #f5f7fb;
    }

    .pres-page {
        direction: rtl;
    }

    .breadcrumb-modern {
        background: #fff;
        border-bottom: 1px solid #eee;
    }

    .card-modern {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,.08);
        border: none;
        overflow: hidden;
    }

    .card-header-modern {
        padding: 15px 20px;
        font-weight: 700;
        font-size: 16px;
    }

    .img-box {
        text-align: center;
        padding: 20px;
    }

    .pres-img {
        max-height: 450px;
        max-width: 100%;
        object-fit: contain;
        border-radius: 12px;
    }

    .table th {
        background: #f8f9fa;
        font-size: 13px;
        color: #666;
        width: 35%;
        white-space: nowrap;
    }

    .table td {
        font-size: 14px;
    }

    .badge-modern {
        padding: 8px 14px;
        border-radius: 30px;
        font-size: 12px;
        font-weight: 600;
    }

    .btn-modern {
        border-radius: 12px;
        padding: 10px 18px;
        font-weight: 600;
    }

    .actions {
        gap: 10px;
        display: flex;
        flex-wrap: wrap;
    }

    @@media(max-width:768px) {
        .pres-img {
            max-height: 300px;
        }
    }

</style>

<div class="pres-page">

    <!-- Breadcrumb -->
    <div class="breadcrumb-modern py-3">
        <div class="container">

            <a asp-controller="Home" asp-action="Index">
                الرئيسية
            </a>

            <span class="mx-2">/</span>

            <a asp-controller="Prescription"
               asp-action="MyPrescriptions">
                روشتاتي
            </a>

            <span class="mx-2">/</span>

            <strong>
                روشتة #@Model.Id
            </strong>

        </div>
    </div>

    <div class="site-section py-5">

        <div class="container">

            <div class="row">

                <!-- IMAGE -->
                <div class="col-lg-5 mb-4">

                    <div class="card-modern">

                        <div class="card-header-modern bg-primary text-white">
                            صورة الروشتة
                        </div>

                        <div class="img-box">

                            @if (!string.IsNullOrEmpty(Model.ImagePath))
                            {
                                <img src="@Url.Content(Model.ImagePath)"
                                     class="pres-img" />
                            }
                            else
                            {
                                <img src="~/images/no-image.png"
                                     class="pres-img" />
                            }

                        </div>

                    </div>

                </div>

                <!-- INFO -->
                <div class="col-lg-7">

                    <div class="card-modern">

                        <div class="card-header-modern bg-dark text-white">
                            بيانات الروشتة
                        </div>

                        <div class="p-3">

                            <table class="table mb-0">

                                <tbody>

                                    <tr>
                                        <th>الحالة</th>
                                        <td>

                                            @{
                                                var statusClass = Model.Status switch
                                                {
                                                    ePharma_asp_mvc.Models.Enums.PrescriptionStatus.Pending => "bg-warning text-dark",
                                                    ePharma_asp_mvc.Models.Enums.PrescriptionStatus.Accepted => "bg-info text-white",
                                                    ePharma_asp_mvc.Models.Enums.PrescriptionStatus.Completed => "bg-success text-white",
                                                    ePharma_asp_mvc.Models.Enums.PrescriptionStatus.Cancelled => "bg-danger text-white",
                                                    _ => "bg-secondary text-white"
                                                };
                                            }

                                            <span class="badge-modern @statusClass">
                                                @Model.Status
                                            </span>

                                        </td>
                                    </tr>

                                    <tr>
                                        <th>رقم الروشتة</th>
                                        <td>#@Model.Id</td>
                                    </tr>

                                    <tr>
                                        <th>تاريخ الرفع</th>
                                        <td>
                                            @Model.CreatedAt.ToString("dd/MM/yyyy - hh:mm tt")
                                        </td>
                                    </tr>

                                    <tr>
                                        <th>العنوان</th>
                                        <td>@Model.Address</td>
                                    </tr>

                                    <tr>
                                        <th>رقم الهاتف</th>
                                        <td>@Model.PhoneNumber</td>
                                    </tr>

                                    <tr>
                                        <th>الملاحظات</th>
                                        <td>
                                            @(string.IsNullOrEmpty(Model.Notes)
                                                                                        ? "لا توجد ملاحظات"
                                                                                        : Model.Notes)
                                        </td>
                                    </tr>

                                    <tr>
                                        <th>المستخدم</th>
                                        <td>@Model.User?.UserName</td>
                                    </tr>

                                </tbody>

                            </table>

                        </div>

                    </div>

                    <!-- ACTIONS -->
                    <div class="card-modern mt-4 p-3">

                        <div class="actions">

                            <a asp-controller="Prescription"
                               asp-action="MyPrescriptions"
                               class="btn btn-outline-primary btn-modern">

                                رجوع

                            </a>

                            <a href="@Url.Content(Model.ImagePath)"
                               target="_blank"
                               class="btn btn-primary btn-modern">

                                عرض الصورة

                            </a>

                            @if (User.IsInRole("Admin"))
                            {
                                <form asp-action="Delete"
                                      method="post"
                                      onsubmit="return confirm('هل تريد حذف الروشتة؟');">

                                    @Html.AntiForgeryToken()

                                    <input type="hidden" name="id" value="@Model.Id" />

                                    <button class="btn btn-danger btn-modern">
                                        حذف
                                    </button>

                                </form>
                            }

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>