@model List<ShoppingCartItem>

@{
    ViewData["Title"] = "سلة التسوق";
}

<style>

    body {
        background: #f5f7fb;
    }

    .cart-page {
        direction: rtl;
    }

    .cart-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,.08);
        padding: 20px;
        border: none;
        transition: .3s;
    }

        .cart-card:hover {
            transform: translateY(-3px);
        }

    .cart-table th {
        font-size: 13px;
        color: #666;
        font-weight: 600;
        white-space: nowrap;
    }

    .cart-table td {
        vertical-align: middle;
    }

    .product-img {
        width: 70px;
        height: 70px;
        object-fit: contain;
        border-radius: 12px;
        border: 1px solid #eee;
        padding: 5px;
        background: #fff;
    }

    .qty-box {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .qty-btn {
        border: 1px solid #0d6efd;
        background: #fff;
        color: #0d6efd;
        padding: 5px 10px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: bold;
        transition: .2s;
    }

        .qty-btn:hover {
            background: #0d6efd;
            color: #fff;
        }

    .coupon-box input {
        border-radius: 12px;
        padding: 12px;
    }

    .summary-card {
        background: #fff;
        border-radius: 20px;
        padding: 25px;
        box-shadow: 0 10px 30px rgba(0,0,0,.08);
    }

    .total-price {
        font-size: 28px;
        font-weight: 700;
        color: #0d6efd;
    }

    .btn-modern {
        border-radius: 12px;
        padding: 12px 18px;
        font-weight: 600;
    }

    .breadcrumb-modern {
        background: #fff;
        border-bottom: 1px solid #eee;
    }

    @@media(max-width:768px) {
        .summary-card {
            margin-top: 20px;
        }
    }

</style>

<div class="cart-page">

    <!-- Breadcrumb -->
    <div class="breadcrumb-modern py-3">
        <div class="container">

            <a asp-controller="Home" asp-action="Index">الرئيسية</a>
            <span class="mx-2">/</span>
            <strong>سلة التسوق</strong>

        </div>
    </div>

    <div class="site-section py-5">
        <div class="container">

            <div class="row">

                <!-- CART TABLE -->
                <div class="col-lg-8 mb-4">

                    <div class="cart-card">

                        <div class="table-responsive">

                            <table class="table cart-table">

                                <thead>
                                    <tr>
                                        <th>الصورة</th>
                                        <th>المنتج</th>
                                        <th>السعر</th>
                                        <th>الكمية</th>
                                        <th>الإجمالي</th>
                                        <th></th>
                                    </tr>
                                </thead>

                                <tbody>

                                    @foreach (var item in Model)
                                    {
                                        <tr>

                                            <td>
                                                <img src="@Url.Content(item.Product.ImageUrl)"
                                                     class="product-img" />
                                            </td>

                                            <td>
                                                <strong>@item.Product.Name</strong>
                                            </td>

                                            <td>
                                                @item.Product.Price.ToString("N2") ج.م
                                            </td>

                                            <td>

                                                <div class="qty-box">

                                                    <a asp-action="DecreaseQuantity"
                                                       asp-route-id="@item.Id"
                                                       class="qty-btn">
                                                        -
                                                    </a>

                                                    <span>
                                                        @item.Quantity
                                                    </span>

                                                    <a asp-action="IncreaseQuantity"
                                                       asp-route-id="@item.Id"
                                                       class="qty-btn">
                                                        +
                                                    </a>

                                                </div>

                                            </td>

                                            <td>
                                                <strong>
                                                    @((item.Product.Price * item.Quantity).ToString("N2")) ج.م
                                                </strong>
                                            </td>

                                            <td>
                                                <a asp-action="RemoveFromShoppingCart"
                                                   asp-route-id="@item.Id"
                                                   class="btn btn-danger btn-sm btn-modern">
                                                    حذف
                                                </a>
                                            </td>

                                        </tr>
                                    }

                                </tbody>

                            </table>

                        </div>

                        <div class="mt-3">

                            <a asp-controller="Home"
                               asp-action="Shop"
                               class="btn btn-outline-primary btn-modern">

                                متابعة التسوق

                            </a>

                        </div>

                    </div>

                    <!-- COUPON -->
                    <div class="cart-card mt-4">

                        <h5 class="mb-2">كوبون خصم</h5>

                        <p class="text-muted">
                            أدخل كود الخصم إذا كان لديك واحد
                        </p>

                        <div class="row coupon-box">

                            <div class="col-md-8 mb-2">
                                <input type="text"
                                       class="form-control"
                                       placeholder="كود الخصم" />
                            </div>

                            <div class="col-md-4">
                                <button class="btn btn-primary btn-modern w-100">
                                    تطبيق
                                </button>
                            </div>

                        </div>

                    </div>

                </div>

                <!-- SUMMARY -->
                <div class="col-lg-4">

                    <div class="summary-card">

                        <h4 class="mb-3">ملخص الطلب</h4>

                        @{
                            decimal cartTotal = 0;
                            foreach (var item in Model)
                            {
                                cartTotal += item.Product.Price * item.Quantity;
                            }
                        }

                        <div class="d-flex justify-content-between mb-2">
                            <span>الإجمالي الفرعي</span>
                            <strong>@cartTotal.ToString("N2") ج.م</strong>
                        </div>

                        <hr />

                        <div class="d-flex justify-content-between mb-3">
                            <span>الإجمالي</span>
                            <span class="total-price">
                                @cartTotal.ToString("N2") ج.م
                            </span>
                        </div>

                        <a asp-controller="Order"
                           asp-action="CheckOut"
                           class="btn btn-primary btn-modern w-100">

                            إتمام الطلب

                        </a>

                    </div>

                </div>

            </div>

        </div>
    </div>

</div>