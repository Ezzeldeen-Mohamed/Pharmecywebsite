<div class="bg-light py-3">
    <div class="container">
        <div class="row">
            <div class="col-md-12 mb-0">
                <a asp-controller="Home" asp-action="Index">Home</a>
                <span class="mx-2 mb-0">/</span>
                <strong class="text-black">Thank You</strong>
            </div>
        </div>
    </div>
</div>

<div class="site-section">
    <div class="container">
        <div class="row">
            <div class="col-md-12 text-center">
                <span class="icon-check_circle display-3 text-success"></span>
                <h2 class="display-3 text-black">Thank you!</h2>

                <!-- تعديل الصياغة هنا لتقرأ بشكل طبيعي -->
                <p class="lead mb-5">Your @ViewBag.nama has been successfully processed.</p>

                <p>
                    @if (ViewBag.nama == "Prescription")
                    {
                        <!-- لو جاي من رفع روشتة نوجهه لصفحة الروشتات بتاعته -->
                        <a asp-controller="Prescription" asp-action="MyPrescriptions" class="btn btn-md height-auto px-4 py-3 btn-primary">Track Your Prescriptions</a>
                    }
                    else
                    {
                        <!-- لو جاي من الشراء العادي يروح لطلباته -->
                        <a asp-controller="Order" asp-action="MyOrders" class="btn btn-md height-auto px-4 py-3 btn-primary">Check your Orders</a>
                    }
                </p>
            </div>
        </div>
    </div>
</div>