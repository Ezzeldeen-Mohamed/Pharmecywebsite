@model List<ShoppingCartItem>

@{
    ViewData["Title"] = "إتمام الطلب";
}

<div dir="rtl">

    <!-- Breadcrumb -->
    <div class="bg-light py-3 border-bottom">
        <div class="container">
            <a asp-controller="Home" asp-action="Index" class="text-decoration-none">
                الرئيسية
            </a>
            <span class="mx-2">/</span>
            <strong>إتمام الطلب</strong>
        </div>
    </div>

    <div class="site-section py-5">
        <div class="container">

            <form asp-controller="Order"
                  asp-action="CheckOut"
                  method="post"
                  enctype="multipart/form-data">

                <div class="row g-4">

                    <!-- بيانات العميل -->
                    <div class="col-lg-7">

                        <div class="card border-0 shadow-sm rounded-4">
                            <div class="card-body p-4">

                                <h3 class="mb-4 fw-bold">
                                    📍 بيانات التوصيل
                                </h3>

                                <div class="form-floating mb-4">
                                    <textarea name="customAddress"
                                              class="form-control"
                                              placeholder="العنوان"
                                              style="height:120px"
                                              required></textarea>
                                    <label>عنوان التوصيل</label>
                                </div>

                                <div class="form-floating mb-4">
                                    <textarea name="customerNotes"
                                              class="form-control"
                                              placeholder="ملاحظات"
                                              style="height:100px"></textarea>
                                    <label>ملاحظات إضافية</label>
                                </div>

                                <div class="alert alert-success rounded-3 mb-0">
                                    <h6 class="fw-bold mb-2">
                                        💵 الدفع عند الاستلام
                                    </h6>

                                    <small>
                                        يمكنك الدفع نقداً عند استلام الطلب.
                                    </small>
                                </div>

                            </div>
                        </div>

                    </div>

                    <!-- ملخص الطلب -->
                    <div class="col-lg-5">

                        <div class="card border-0 shadow-sm rounded-4 sticky-top"
                             style="top:20px;">

                            <div class="card-body p-4">

                                <h3 class="fw-bold mb-4">
                                    🛒 ملخص الطلب
                                </h3>

                                <table class="table align-middle">

                                    <thead>
                                        <tr>
                                            <th>المنتج</th>
                                            <th class="text-center">الإجمالي</th>
                                        </tr>
                                    </thead>

                                    <tbody>

                                        @{
                                            decimal cartTotal = 0;
                                        }

                                        @foreach (var item in Model)
                                        {
                                            decimal itemTotal =
                                            item.Product.Price * item.Quantity;

                                            cartTotal += itemTotal;

                                            <tr>
                                                <td>
                                                    <div>
                                                        <strong>
                                                            @item.Product.Name
                                                        </strong>
                                                        <br />
                                                        <small class="text-muted">
                                                            الكمية: @item.Quantity
                                                        </small>
                                                    </div>
                                                </td>

                                                <td class="text-center">
                                                    @itemTotal.ToString("N2") ج.م
                                                </td>
                                            </tr>
                                        }

                                    </tbody>
                                </table>

                                <hr />

                                <div class="d-flex justify-content-between mb-2">
                                    <span>المجموع الفرعي</span>
                                    <strong>
                                        @cartTotal.ToString("N2") ج.م
                                    </strong>
                                </div>

                                <div class="d-flex justify-content-between fs-5 fw-bold text-primary">
                                    <span>الإجمالي</span>
                                    <span>
                                        @cartTotal.ToString("N2") ج.م
                                    </span>
                                </div>

                                <button type="submit"
                                        class="btn btn-primary btn-lg w-100 mt-4 rounded-3">

                                    تأكيد الطلب
                                </button>

                            </div>
                        </div>

                    </div>

                </div>

            </form>

        </div>
    </div>

</div>