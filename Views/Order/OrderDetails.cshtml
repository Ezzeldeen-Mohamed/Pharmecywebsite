@using ePharma_asp_mvc.Models.Enums
@model Order

@{
    ViewData["Title"] = "Order Details";
}

<style>
    body {
        background-color: #f8f9fa;
    }

    .order-card {
        background: #fff;
        border-radius: 16px;
        padding: 25px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        margin-bottom: 25px;
    }

    .section-title {
        font-size: 18px;
        font-weight: 700;
        margin-bottom: 20px;
        color: #222;
    }

    .status-badge {
        padding: 8px 18px;
        border-radius: 30px;
        font-size: 13px;
        font-weight: 600;
        display: inline-block;
    }

    .product-image {
        width: 70px;
        height: 70px;
        object-fit: contain;
        border-radius: 12px;
        background: #fff;
        border: 1px solid #eee;
        padding: 5px;
    }

    .table td,
    .table th {
        vertical-align: middle !important;
    }

    .info-label {
        font-size: 13px;
        color: #888;
        margin-bottom: 3px;
    }

    .info-value {
        font-size: 15px;
        font-weight: 500;
        color: #222;
    }

    .total-price {
        font-size: 32px;
        font-weight: 700;
        color: #0d6efd;
    }

    .custom-table thead {
        background: #f5f5f5;
    }

    .custom-table th {
        border: none;
        font-size: 13px;
        text-transform: uppercase;
        color: #666;
        font-weight: 600;
    }

    .custom-table td {
        border-top: 1px solid #eee;
    }

    .btn-custom {
        border-radius: 10px;
        padding: 10px 22px;
        font-weight: 600;
    }

    .empty-note {
        background: #f8f9fa;
        border-radius: 10px;
        padding: 12px;
        color: #777;
        font-size: 14px;
    }
</style>

<!-- Breadcrumb -->
<div class="bg-white border-bottom py-3">
    <div class="container">
        <a asp-controller="Home"
           asp-action="Index">Home</a>

        <span class="mx-2">/</span>

        <a asp-action="MyOrders">My Orders</a>

        <span class="mx-2">/</span>

        <strong>Order #@Model.Id</strong>
    </div>
</div>

<div class="site-section">
    <div class="container">

        <!-- Top Summary -->
        <div class="order-card">

            <div class="row align-items-center">

                <div class="col-md-8">

                    <h2 class="mb-2">
                        Order #@Model.Id
                    </h2>

                    <p class="text-muted mb-3">
                        Ordered on
                        @Model.TimeOrdered.ToString("dd MMM yyyy - hh:mm tt")
                    </p>

                    @{
                        var statusClass = Model.Status switch
                        {
                            OrderStatus.Pending => "bg-warning text-dark",
                            OrderStatus.Accepted => "bg-info text-white",
                            OrderStatus.Completed => "bg-success text-white",
                            OrderStatus.Cancelled => "bg-danger text-white",
                            _ => "bg-dark text-white"
                        };
                    }

                    <span class="status-badge @statusClass">
                        @Model.Status
                    </span>

                </div>

                <div class="col-md-4 text-md-right mt-4 mt-md-0">

                    <div class="info-label">
                        Total Price
                    </div>

                    <div class="total-price">
                        $@Model.TotalPrice
                    </div>

                </div>

            </div>

        </div>

        <!-- Shipping -->
        <div class="row">

            <div class="col-md-6 mb-4">

                <div class="order-card h-100">

                    <h3 class="section-title">
                        Shipping Information
                    </h3>

                    <div class="mb-3">
                        <div class="info-label">
                            Delivery Address
                        </div>

                        <div class="info-value">
                            @Model.CustomAddress
                        </div>
                    </div>

                    <div>
                        <div class="info-label">
                            Customer Notes
                        </div>

                        @if (!string.IsNullOrWhiteSpace(Model.CustomerNotes))
                        {
                            <div class="info-value">
                                @Model.CustomerNotes
                            </div>
                        }
                        else
                        {
                            <div class="empty-note">
                                No additional notes.
                            </div>
                        }
                    </div>

                </div>

            </div>

            <div class="col-md-6 mb-4">

                <div class="order-card h-100">

                    <h3 class="section-title">
                        Payment Information
                    </h3>

                    <div class="mb-3">
                        <div class="info-label">
                            Payment Method
                        </div>

                        <div class="info-value">
                            Cash On Delivery
                        </div>
                    </div>

                    <div>
                        <div class="info-label">
                            Payment Status
                        </div>

                        <div class="info-value">
                            Pending Until Delivery
                        </div>
                    </div>

                </div>

            </div>

        </div>

        <!-- Products -->
        <div class="order-card">

            <h3 class="section-title">
                Ordered Products
            </h3>

            <div class="table-responsive">

                <table class="table custom-table">

                    <thead>
                        <tr>
                            <th>Image</th>
                            <th>Product</th>
                            <th class="text-center">Price</th>
                            <th class="text-center">Quantity</th>
                            <th class="text-right">Total</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var item in Model.OrderItems)
                        {
                            <tr>

                                <td>
                                    <img src="@item.Product.ImageUrl"
                                         class="product-image"
                                         alt="@item.Product.Name" />
                                </td>

                                <td>
                                    <strong>
                                        @item.Product.Name
                                    </strong>
                                </td>

                                <td class="text-center">
                                    $@item.Product.Price
                                </td>

                                <td class="text-center">
                                    @item.Quantity
                                </td>

                                <td class="text-right font-weight-bold">
                                    $@(item.Product.Price* item.Quantity)
                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

        <!-- Buttons -->
        <div class="d-flex justify-content-between align-items-center flex-wrap">

            <div class="mb-3">

                <a asp-action="MyOrders"
                   class="btn btn-outline-primary btn-custom">
                    Back To Orders
                </a>

                <a asp-controller="Home"
                   asp-action="Shop"
                   class="btn btn-primary btn-custom ml-2">
                    Continue Shopping
                </a>

            </div>

            @if (Model.Status == OrderStatus.Pending)
            {
                <form asp-action="CancelOrder"
                      method="post"
                      onsubmit="return confirm('Are you sure you want to cancel this order?');">

                    @Html.AntiForgeryToken()

                    <input type="hidden"
                           name="id"
                           value="@Model.Id" />

                    <button type="submit"
                            class="btn btn-danger btn-custom">
                        Cancel Order
                    </button>

                </form>
            }

        </div>

    </div>
</div>