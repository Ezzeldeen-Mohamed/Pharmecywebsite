@using ePharma_asp_mvc.Models.Enums
@model Order

@{
    ViewData["Title"] = "تفاصيل الطلب";
}

<style>

    body {
        background: #f5f7fb;
    }

    .order-page {
        direction: rtl;
    }

    .order-card {
        background: #fff;
        border-radius: 20px;
        padding: 25px;
        box-shadow: 0 10px 30px rgba(0,0,0,.08);
        margin-bottom: 25px;
        border: none;
        transition: .3s;
    }

        .order-card:hover {
            transform: translateY(-3px);
        }

    .section-title {
        font-size: 20px;
        font-weight: 700;
        margin-bottom: 20px;
        color: #212529;
    }

    .status-badge {
        padding: 10px 18px;
        border-radius: 30px;
        font-size: 13px;
        font-weight: 600;
        display: inline-block;
    }

    .product-image {
        width: 75px;
        height: 75px;
        object-fit: contain;
        border-radius: 12px;
        background: #fff;
        border: 1px solid #eee;
        padding: 5px;
    }

    .table td,
    .table th {
        vertical-align: middle !important;
    }

    .info-label {
        font-size: 13px;
        color: #888;
        margin-bottom: 5px;
    }

    .info-value {
        font-size: 15px;
        font-weight: 500;
        color: #222;
    }

    .total-price {
        font-size: 34px;
        font-weight: 700;
        color: #0d6efd;
    }

    .custom-table thead {
        background: #f8f9fa;
    }

    .custom-table th {
        border: none;
        color: #666;
        font-size: 13px;
        font-weight: 600;
    }

    .custom-table td {
        border-top: 1px solid #eee;
    }

    .btn-custom {
        border-radius: 12px;
        padding: 10px 22px;
        font-weight: 600;
    }

    .empty-note {
        background: #f8f9fa;
        border-radius: 10px;
        padding: 12px;
        color: #777;
        font-size: 14px;
    }

    .breadcrumb-modern {
        background: white;
        border-bottom: 1px solid #eee;
    }

        .breadcrumb-modern a {
            text-decoration: none;
        }

    @@media(max-width:768px) {

        .order-card {
            padding: 18px;
        }

        .total-price {
            font-size: 26px;
        }

        .custom-table {
            min-width: 700px;
        }

        .section-title {
            font-size: 18px;
        }
    }

</style>

<div class="order-page">

    <!-- Breadcrumb -->
    <div class="breadcrumb-modern py-3">
        <div class="container">

            <a asp-controller="Home"
               asp-action="Index">
                الرئيسية
            </a>

            <span class="mx-2">/</span>

            <a asp-action="MyOrders">
                طلباتي
            </a>

            <span class="mx-2">/</span>

            <strong>
                الطلب رقم #@Model.Id
            </strong>

        </div>
    </div>

    <div class="site-section py-5">

        <div class="container">

            <!-- Top Summary -->
            <div class="order-card">

                <div class="row align-items-center">

                    <div class="col-md-8">

                        <h2 class="mb-2">
                            الطلب رقم #@Model.Id
                        </h2>

                        <p class="text-muted mb-3">
                            تاريخ الطلب :
                            @Model.TimeOrdered.ToString("dd/MM/yyyy - hh:mm tt")
                        </p>

                        @{
                            var statusClass = Model.Status switch
                            {
                                OrderStatus.Pending => "bg-warning text-dark",
                                OrderStatus.Accepted => "bg-info text-white",
                                OrderStatus.Completed => "bg-success text-white",
                                OrderStatus.Cancelled => "bg-danger text-white",
                                _ => "bg-dark text-white"
                            };
                        }

                        <span class="status-badge @statusClass">

                            @switch (Model.Status)
                            {
                                case OrderStatus.Pending:
                                    @:قيد المراجعة
                                    break;

                                case OrderStatus.Accepted:
                                    @:تم القبول
                                    break;

                                case OrderStatus.Completed:
                                    @:مكتمل
                                    break;

                                case OrderStatus.Cancelled:
                                    @:ملغي
                                    break;
                            }

                        </span>

                    </div>

                    <div class="col-md-4 text-md-left mt-4 mt-md-0">

                        <div class="info-label">
                            إجمالي الطلب
                        </div>

                        <div class="total-price">
                            @Model.TotalPrice.ToString("N2") ج.م
                        </div>

                    </div>

                </div>

            </div>

            <!-- Shipping & Payment -->

            <div class="row">

                <div class="col-md-6 mb-4">

                    <div class="order-card h-100">

                        <h3 class="section-title">
                            معلومات التوصيل
                        </h3>

                        <div class="mb-3">

                            <div class="info-label">
                                عنوان التوصيل
                            </div>

                            <div class="info-value">
                                @Model.CustomAddress
                            </div>

                        </div>

                        <div>

                            <div class="info-label">
                                ملاحظات العميل
                            </div>

                            @if (!string.IsNullOrWhiteSpace(Model.CustomerNotes))
                            {
                                <div class="info-value">
                                    @Model.CustomerNotes
                                </div>
                            }
                            else
                            {
                                <div class="empty-note">
                                    لا توجد ملاحظات إضافية.
                                </div>
                            }

                        </div>

                    </div>

                </div>

                <div class="col-md-6 mb-4">

                    <div class="order-card h-100">

                        <h3 class="section-title">
                            معلومات الدفع
                        </h3>

                        <div class="mb-3">

                            <div class="info-label">
                                طريقة الدفع
                            </div>

                            <div class="info-value">
                                الدفع عند الاستلام
                            </div>

                        </div>

                        <div>

                            <div class="info-label">
                                حالة الدفع
                            </div>

                            <div class="info-value">
                                يتم الدفع عند الاستلام
                            </div>

                        </div>

                    </div>

                </div>

            </div>

            <!-- Products -->

            <div class="order-card">

                <h3 class="section-title">
                    المنتجات المطلوبة
                </h3>

                <div class="table-responsive">

                    <table class="table custom-table">

                        <thead>

                            <tr>
                                <th>الصورة</th>
                                <th>المنتج</th>
                                <th class="text-center">السعر</th>
                                <th class="text-center">الكمية</th>
                                <th class="text-center">الإجمالي</th>
                            </tr>

                        </thead>

                        <tbody>
                            @foreach (var item in Model.OrderItems)
                            {
                                <tr>

                                    <td>
                                        <img src="@item.Product.ImageUrl"
                                             class="product-image"
                                             alt="@item.Product.Name" />
                                    </td>

                                    <td>
                                        <strong>
                                            @item.Product.Name
                                        </strong>
                                    </td>

                                    <td class="text-center">
                                        @item.Product.Price.ToString("N2") ج.م
                                    </td>

                                    <td class="text-center">
                                        @item.Quantity
                                    </td>

                                    <td class="text-center fw-bold">
                                        @((item.Product.Price * item.Quantity).ToString("N2")) ج.م
                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>

            </div>

            <!-- Buttons -->

            <div class="d-flex justify-content-between align-items-center flex-wrap mt-4">

                <div class="mb-3">

                    <a asp-action="MyOrders"
                       class="btn btn-outline-primary btn-custom">

                        رجوع للطلبات

                    </a>

                    <a asp-controller="Home"
                       asp-action="Shop"
                       class="btn btn-primary btn-custom ms-2">

                        متابعة التسوق

                    </a>

                </div>

                @if (Model.Status == OrderStatus.Pending)
                {
                    <form asp-action="CancelOrder"
                          method="post"
                          onsubmit="return confirm('هل أنت متأكد من إلغاء هذا الطلب؟');">

                        @Html.AntiForgeryToken()

                        <input type="hidden"
                               name="id"
                               value="@Model.Id" />

                        <button type="submit"
                                class="btn btn-danger btn-custom">

                            إلغاء الطلب

                        </button>

                    </form>
                }

            </div>

        </div>

    </div>

</div>