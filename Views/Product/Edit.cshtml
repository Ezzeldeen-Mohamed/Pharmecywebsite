@model Product

@{
    ViewData["Title"] = "تعديل المنتج";
}

<style>

    body {
        background: #f5f7fb;
    }

    .product-page {
        direction: rtl;
    }

    .product-card {
        background: #fff;
        border-radius: 22px;
        box-shadow: 0 10px 30px rgba(0,0,0,.08);
        border: none;
        overflow: hidden;
    }

    .product-header {
        background: linear-gradient(135deg, #ffc107, #e0a800);
        color: #212529;
        padding: 20px;
        font-weight: 700;
        font-size: 18px;
    }

    .product-body {
        padding: 25px;
    }

    label {
        font-weight: 600;
        margin-bottom: 6px;
        color: #333;
    }

    .form-control {
        border-radius: 12px;
        padding: 12px;
        font-size: 14px;
    }

    .btn-modern {
        border-radius: 12px;
        padding: 10px 18px;
        font-weight: 600;
    }

    .img-preview {
        width: 150px;
        height: 150px;
        object-fit: cover;
        border-radius: 14px;
        border: 1px solid #eee;
        margin-top: 10px;
    }

    .btn-group-modern {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .hint {
        font-size: 12px;
        color: #6c757d;
    }

    .section-box {
        background: #f8f9fa;
        padding: 12px;
        border-radius: 12px;
        margin-bottom: 15px;
    }

    @@media(max-width:768px) {
        .product-body {
            padding: 18px;
        }
    }

</style>

<div class="product-page">

    <div class="container mt-5">

        <div class="row justify-content-center">

            <div class="col-lg-8 col-md-10">

                <div class="product-card">

                    <!-- HEADER -->
                    <div class="product-header">
                        ✏️ تعديل المنتج
                    </div>

                    <div class="product-body">

                        <form asp-action="Edit"
                              method="post"
                              enctype="multipart/form-data">

                            <input type="hidden" asp-for="Id" />

                            <!-- VALIDATION -->
                            <div asp-validation-summary="All"
                                 class="text-danger mb-3"></div>

                            <!-- NAME -->
                            <div class="mb-3">

                                <label>اسم المنتج</label>

                                <input asp-for="Name"
                                       class="form-control" />

                                <span asp-validation-for="Name"
                                      class="text-danger"></span>

                            </div>

                            <!-- DESCRIPTION -->
                            <div class="mb-3">

                                <label>الوصف</label>

                                <textarea asp-for="Description"
                                          class="form-control"
                                          rows="4"></textarea>

                                <span asp-validation-for="Description"
                                      class="text-danger"></span>

                            </div>

                            <!-- PRICE -->
                            <div class="mb-3">

                                <label>السعر</label>

                                <input asp-for="Price"
                                       class="form-control" />

                                <span asp-validation-for="Price"
                                      class="text-danger"></span>

                            </div>

                            <!-- STOCK -->
                            <div class="mb-3">

                                <label>المخزون</label>

                                <input asp-for="Stock"
                                       class="form-control" />

                                <span asp-validation-for="Stock"
                                      class="text-danger"></span>

                            </div>

                            <!-- CATEGORY -->
                            <div class="mb-3">

                                <label>القسم</label>

                                <input asp-for="Category"
                                       class="form-control" />

                                <span asp-validation-for="Category"
                                      class="text-danger"></span>

                            </div>

                            <!-- CURRENT IMAGE -->
                            @if (!string.IsNullOrEmpty(Model.ImageUrl))
                            {
                                <div class="section-box">

                                    <label>الصورة الحالية</label>

                                    <br />

                                    <img src="@Model.ImageUrl"
                                         class="img-preview" />

                                </div>
                            }

                            <!-- NEW IMAGE -->
                            <div class="mb-3">

                                <label>تغيير الصورة</label>

                                <input type="file"
                                       name="imageFile"
                                       class="form-control"
                                       accept="image/*" />

                                <div class="hint mt-1">
                                    يمكنك رفع صورة جديدة واستبدال القديمة
                                </div>

                            </div>

                            <!-- BUTTONS -->
                            <div class="btn-group-modern">

                                <button type="submit"
                                        class="btn btn-warning btn-modern">

                                    💾 تحديث المنتج

                                </button>

                                <a asp-action="Index"
                                   class="btn btn-outline-secondary btn-modern">

                                    إلغاء

                                </a>

                            </div>

                        </form>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>