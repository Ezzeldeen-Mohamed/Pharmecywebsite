@model Product

@{
    ViewData["Title"] = "إضافة منتج";
}

<style>

    body {
        background: #f5f7fb;
    }

    .product-page {
        direction: rtl;
    }

    .product-card {
        background: #fff;
        border-radius: 22px;
        box-shadow: 0 10px 30px rgba(0,0,0,.08);
        border: none;
        overflow: hidden;
    }

    .product-header {
        background: linear-gradient(135deg, #198754, #157347);
        color: #fff;
        padding: 20px;
        font-weight: 700;
        font-size: 18px;
    }

    .product-body {
        padding: 25px;
    }

    label {
        font-weight: 600;
        margin-bottom: 6px;
        color: #333;
    }

    .form-control {
        border-radius: 12px;
        padding: 12px;
        font-size: 14px;
    }

    .btn-modern {
        border-radius: 12px;
        padding: 10px 18px;
        font-weight: 600;
    }

    .preview-img {
        max-height: 250px;
        border-radius: 16px;
        box-shadow: 0 10px 25px rgba(0,0,0,.1);
        display: none;
    }

    .hint {
        font-size: 12px;
        color: #6c757d;
    }

    .btn-group-modern {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .file-box {
        border: 2px dashed #198754;
        border-radius: 14px;
        padding: 15px;
        text-align: center;
        background: #f8fff9;
        cursor: pointer;
        transition: .3s;
    }

        .file-box:hover {
            background: #eaffea;
        }

    @@media(max-width:768px) {
        .product-body {
            padding: 18px;
        }
    }

</style>

<div class="product-page">

    <div class="container mt-5">

        <div class="row justify-content-center">

            <div class="col-lg-8 col-md-10">

                <div class="product-card">

                    <div class="product-header">
                        ➕ إضافة منتج جديد
                    </div>

                    <div class="product-body">

                        <form asp-controller="Product"
                              asp-action="Create"
                              method="post"
                              enctype="multipart/form-data">

                            <!-- VALIDATION -->
                            <div asp-validation-summary="All"
                                 class="text-danger mb-3"></div>

                            <!-- NAME -->
                            <div class="mb-3">

                                <label>اسم المنتج</label>

                                <input asp-for="Name"
                                       class="form-control"
                                       placeholder="أدخل اسم المنتج" />

                                <span asp-validation-for="Name"
                                      class="text-danger"></span>

                            </div>

                            <!-- DESCRIPTION -->
                            <div class="mb-3">

                                <label>الوصف</label>

                                <textarea asp-for="Description"
                                          class="form-control"
                                          rows="4"
                                          placeholder="وصف المنتج"></textarea>

                                <span asp-validation-for="Description"
                                      class="text-danger"></span>

                            </div>

                            <!-- PRICE -->
                            <div class="mb-3">

                                <label>السعر</label>

                                <input asp-for="Price"
                                       type="number"
                                       step="0.01"
                                       class="form-control"
                                       placeholder="السعر بالجنيه" />

                                <span asp-validation-for="Price"
                                      class="text-danger"></span>

                            </div>

                            <!-- STOCK -->
                            <div class="mb-3">

                                <label>المخزون</label>

                                <input asp-for="Stock"
                                       type="number"
                                       class="form-control"
                                       placeholder="عدد القطع المتاحة" />

                                <span asp-validation-for="Stock"
                                      class="text-danger"></span>

                            </div>

                            <!-- CATEGORY -->
                            <div class="mb-3">

                                <label>القسم</label>

                                <input asp-for="Category"
                                       class="form-control"
                                       placeholder="مثال: أدوية / فيتامينات" />

                                <span asp-validation-for="Category"
                                      class="text-danger"></span>

                            </div>

                            <!-- IMAGE -->
                            <div class="mb-3">

                                <label>صورة المنتج</label>

                                <input type="file"
                                       name="imageFile"
                                       class="form-control"
                                       accept="image/*" />

                                <div class="hint mt-1">
                                    يفضل صورة واضحة بجودة عالية
                                </div>

                            </div>

                            <!-- PREVIEW -->
                            <div class="text-center mb-4">

                                <img id="previewImage"
                                     class="preview-img img-fluid" />

                            </div>

                            <!-- BUTTONS -->
                            <div class="btn-group-modern">

                                <button type="submit"
                                        class="btn btn-success btn-modern">

                                    💾 حفظ المنتج

                                </button>

                                <a asp-controller="Product"
                                   asp-action="Index"
                                   class="btn btn-outline-secondary btn-modern">

                                    إلغاء

                                </a>

                            </div>

                        </form>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>

        document.querySelector('input[name="imageFile"]')
            .addEventListener('change', function (e) {

                const file = e.target.files[0];

                if (file) {

                    const reader = new FileReader();

                    reader.onload = function () {

                        const img =
                            document.getElementById('previewImage');

                        img.src = reader.result;
                        img.style.display = 'block';
                    };

                    reader.readAsDataURL(file);
                }

            });

    </script>
}