@model IEnumerable<Product>

@{
    ViewData["Title"] = "الصفحة الرئيسية";
}

<!-- غطاء الصفحة الترحيبي (Hero Banner) -->
<div class="site-blocks-cover" style="background-image: url('../images/hero_1.jpg'); background-size: cover; background-position: center;">
    <div class="container">
        <div class="row">
            <div class="col-lg-7 mr-auto align-self-center text-right">
                <div class="site-block-cover-content p-4 p-md-5 bg-white-opacity-8 rounded shadow">
                    <h2 class="text-primary font-weight-bold h5 mb-3">أدوية فعالة ورعاية طبية متجددة يومياً</h2>
                    <h1 class="display-4 font-weight-bold text-black mb-4">مرحباً بكم في فارما</h1>
                    <p>
                        <a asp-action="Shop" class="btn btn-primary px-5 py-3 rounded-pill shadow font-weight-bold">تسوق الآن</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- صناديق العروض الترويجية المتداخلة (Overlap Banners) -->
<div class="site-section pt-0">
    <div class="container">
        <div class="row align-items-stretch section-overlap text-right">
            <div class="col-md-6 col-lg-4 mb-4 mb-lg-0">
                <div class="banner-wrap bg-primary h-100 p-4 rounded shadow-sm text-white custom-card-hover">
                    <a href="#" class="h-100 d-block text-white text-decoration-none">
                        <h5 class="font-weight-bold mb-3"><i class="fa fa-truck ml-2"></i> شحن مجاني بالكامل</h5>
                        <p class="small text-white-50">نوفر لك خدمة التوصيل المجاني والسريع لجميع طلبيات الأدوية والمستلزمات الطبية.</p>
                    </a>
                </div>
            </div>
            <div class="col-md-6 col-lg-4 mb-4 mb-lg-0">
                <div class="banner-wrap bg-info h-100 p-4 rounded shadow-sm text-white custom-card-hover">
                    <a href="#" class="h-100 d-block text-white text-decoration-none">
                        <h5 class="font-weight-bold mb-3"><i class="fa fa-percentage ml-2"></i> خصومات الموسم 50%</h5>
                        <p class="small text-white-50">تخفيضات هائلة وحصرية تصل إلى نصف الثمن على مستحضرات التجميل والعناية الشخصية.</p>
                    </a>
                </div>
            </div>
            <div class="col-md-6 col-lg-4 mb-4 mb-lg-0">
                <div class="banner-wrap bg-warning h-100 p-4 rounded shadow-sm text-dark custom-card-hover">
                    <a href="#" class="h-100 d-block text-dark text-decoration-none">
                        <h5 class="font-weight-bold mb-3"><i class="fa fa-gift ml-2"></i> شراء بطاقة هدايا</h5>
                        <p class="small text-dark-50">أهدِ من تحب بطاقة مشتريات طبية لتضمن لهم رعاية صحية متكاملة في أي وقت.</p>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- قسم المنتجات الأكثر مبيعاً -->
<div class="site-section bg-white">
    <div class="container py-4">
        <div class="row mb-5 text-center">
            <div class="col-12">
                <h2 class="text-uppercase font-weight-bold border-bottom d-inline-block pb-2 px-4">المنتجات الأكثر شعبية</h2>
            </div>
        </div>

        <div class="row text-center">
            @if (Model != null && Model.Any())
            {
                @foreach (var product in Model.Take(6))
                {
                    <div class="col-sm-6 col-lg-4 item mb-5">
                        <div class="card p-3 border shadow-sm rounded h-100 product-card custom-card-hover">
                            <!-- صورة المنتج قابلة للضغط -->
                            <a asp-action="SingleProduct" asp-route-id="@product.Id" class="d-block overflow-hidden rounded bg-white p-3">
                                <img src="@Url.Content(product.ImageUrl)" alt="@product.Name" class="img-fluid" style="height: 220px; object-fit: contain; transition: transform 0.3s;">
                            </a>

                            <!-- اسم المنتج -->
                            <h3 class="h5 text-dark font-weight-bold mt-4 mb-2">
                                <a asp-action="SingleProduct" asp-route-id="@product.Id" class="text-dark text-decoration-none">@product.Name</a>
                            </h3>

                            <!-- السعر -->
                            <p class="price text-primary font-weight-bold h4 mb-3">$@product.Price</p>

                            <!-- زر الإضافة السريعة للكارت -->
                            <div class="mt-auto">
                                <a asp-controller="Order" asp-action="AddToShoppingCart" asp-route-id="@product.Id" class="btn btn-sm btn-primary btn-block py-2 rounded-pill shadow-sm font-weight-bold">
                                    <span class="icon-shopping-basket ml-2"></span> أضف إلى السلة
                                </a>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12">
                    <p class="alert alert-info py-4 text-center rounded font-weight-bold">لا توجد منتجات متوفرة حالياً، يرجى مراجعة الصفحة لاحقاً!</p>
                </div>
            }
        </div>

        <!-- زر استعراض باقي المنتجات -->
        <div class="row mt-4">
            <div class="col-12 text-center">
                <a asp-action="Shop" class="btn btn-outline-primary px-5 py-3 rounded-pill font-weight-bold shadow-sm">عرض جميع المنتجات</a>
            </div>
        </div>
    </div>
</div>