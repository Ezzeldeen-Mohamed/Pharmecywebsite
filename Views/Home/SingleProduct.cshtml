@model Product

@{
    ViewData["Title"] = Model.Name;
}

<!-- شريط التنقل (Breadcrumb) -->
<div class="bg-light py-3 border-bottom text-right">
    <div class="container">
        <div class="row">
            <div class="col-md-12 mb-0">
                <a asp-controller="Home" asp-action="Index" class="text-primary font-weight-bold">الرئيسية</a>
                <span class="mx-2 mb-0 text-muted">/</span>
                <a asp-controller="Product" asp-action="Index" class="text-primary font-weight-bold">المتجر</a>
                <span class="mx-2 mb-0 text-muted">/</span>
                <strong class="text-dark">@Model.Name</strong>
            </div>
        </div>
    </div>
</div>

<!-- عرض تفاصيل المنتج الطبية -->
<div class="site-section bg-white text-right">
    <div class="container py-5">
        <div class="row align-items-start">

            <!-- صورة المنتج الجانبية -->
            <div class="col-md-5 mb-4 mb-md-0 ml-auto">
                <div class="border rounded shadow-sm text-center p-4 bg-light overflow-hidden position-relative">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Url.Content(Model.ImageUrl)" alt="@Model.Name" class="img-fluid transform-hover-lg" style="max-height: 380px; object-fit: contain;" />
                    }
                    else
                    {
                        <img src="~/images/no-image.png" alt="لا توجد صورة" class="img-fluid" style="max-height: 380px;" />
                    }
                </div>
            </div>

            <!-- معلومات وتفاصيل المنتج -->
            <div class="col-md-6">
                <h2 class="text-black font-weight-bold mb-3">@Model.Name</h2>
                <p class="text-secondary lead mb-4">@Model.Description</p>

                <div class="d-flex align-items-center mb-4">
                    <span class="text-muted ml-3 h5 mb-0">السعر الحالي:</span>
                    <h3 class="text-primary font-weight-bold mb-0 h2">$@Model.Price</h3>
                </div>

                <!-- حالة التوفر الفوري في المخزن -->
                <div class="mb-4">
                    @if (Model.Stock > 0)
                    {
                        <div class="alert alert-success d-inline-block px-4 py-2 rounded-pill font-weight-bold shadow-sm mb-0">
                            <i class="fa fa-check-circle ml-2"></i> متوفر في المخزن حالياً (@Model.Stock قطعة متاحة)
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-danger d-inline-block px-4 py-2 rounded-pill font-weight-bold shadow-sm mb-0">
                            <i class="fa fa-times-circle ml-2"></i> عذراً، نفذت الكمية تماماً
                        </div>
                    }
                </div>

                <!-- أزرار الإجراءات والشراء -->
                <div class="d-flex flex-wrap gap-2 mb-5 align-items-center">
                    @if (Model.Stock > 0)
                    {
                        <a asp-controller="Order" asp-action="AddToShoppingCart" asp-route-id="@Model.Id" class="btn btn-primary btn-lg rounded-pill shadow px-5 font-weight-bold ml-2 py-3">
                            <i class="fa fa-shopping-cart ml-2"></i> أضف إلى سلة المشتريات
                        </a>
                    }
                    else
                    {
                        <button class="btn btn-secondary btn-lg rounded-pill px-5 py-3 ml-2 font-weight-bold shadow-sm" disabled>المنتج غير متاح</button>
                    }

                    <!-- خيارات لوحة الأدمن لتحديث بيانات الدواء -->
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-controller="Product" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-lg rounded-pill shadow-sm px-4 ml-2 font-weight-bold text-dark py-3">
                            <i class="fa fa-edit"></i> تعديل البيانات
                        </a>
                        <form asp-controller="Product" asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline" onsubmit="return confirm('هل أنت متأكد تماماً من رغبتك في حذف هذا المنتج الطبي بشكل نهائي؟')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger btn-lg rounded-pill shadow-sm px-4 font-weight-bold py-3">الحذف الحتمي</button>
                        </form>
                    }
                </div>

                <!-- جدول المواصفات الفنية التفصيلي للمنتج -->
                <div class="card shadow-sm border-0 rounded overflow-hidden">
                    <div class="card-header bg-primary text-white font-weight-bold py-3">
                        <i class="fa fa-info-circle ml-2"></i> بطاقة البيانات والمواصفات الطبية
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-striped table-bordered mb-0 text-right">
                            <tbody>
                                <tr>
                                    <th width="35%" class="bg-light font-weight-bold">الرقم المرجعي (ID)</th>
                                    <td class="text-monospace">#@Model.Id</td>
                                </tr>
                                <tr>
                                    <th class="bg-light font-weight-bold">الاسم التجاري العلمي</th>
                                    <td>@Model.Name</td>
                                </tr>
                                <tr>
                                    <th class="bg-light font-weight-bold">السعر النهائي للجمهور</th>
                                    <td class="text-success font-weight-bold">$@Model.Price</td>
                                </tr>
                                <tr>
                                    <th class="bg-light font-weight-bold">التصنيف العلاجي الرئيسي</th>
                                    <td><span class="badge badge-info px-3 py-2 rounded-pill font-weight-bold text-white">@Model.Category</span></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>