@model IEnumerable<Product>

@{
    ViewData["Title"] = "Store";
}

<!-- Breadcrumb -->
<div class="bg-light py-3 border-bottom">

    <div class="container">

        <div class="row">

            <div class="col-md-12 mb-0">

                <a asp-controller="Home"
                   asp-action="Index">

                    Home

                </a>

                <span class="mx-2 text-muted">/</span>

                <strong class="text-black">
                    Store
                </strong>

            </div>

        </div>

    </div>

</div>

<!-- Store -->
<div class="site-section bg-light">

    <div class="container">

        <!-- Header -->
        <div class="row align-items-center mb-5">

            <div class="col-md-6">

                <h2 class="font-weight-bold text-black mb-2">
                    Pharmacy Store
                </h2>

                <p class="text-muted mb-0">
                    Browse medicines and healthcare products.
                </p>

            </div>

            <div class="col-md-6 text-md-right mt-3 mt-md-0">

                <!-- Upload Prescription -->
                <a asp-controller="Prescription"
                   asp-action="Upload"
                   class="btn btn-outline-primary mr-2 shadow-sm">

                    <i class="fa fa-file-medical mr-2"></i>
                    Upload Prescription

                </a>

                <!-- Admin -->
                @if (User.IsInRole("Admin"))
                {
                    <a asp-controller="Product"
                       asp-action="Create"
                       class="btn btn-primary shadow-sm">

                        <i class="fa fa-plus mr-2"></i>
                        Add Product

                    </a>
                }

            </div>

        </div>

        <!-- Products -->
        <div class="row">

            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    <div class="col-md-6 col-lg-4 mb-4">

                        <div class="card border-0 shadow-sm h-100 rounded-lg overflow-hidden product-card">

                            <!-- Product Image -->
                            <div class="bg-white text-center p-3">

                                <a asp-controller="Product"
                                   asp-action="Details"
                                   asp-route-id="@item.Id">

                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@Url.Content(item.ImageUrl)"
                                             class="img-fluid"
                                             style="height:230px; object-fit:contain;" />
                                    }
                                    else
                                    {
                                        <img src="~/images/no-image.png"
                                             class="img-fluid"
                                             style="height:230px; object-fit:contain;" />
                                    }

                            </a>

                        </div>

                        <!-- Body -->
                        <div class="card-body d-flex flex-column">

                            <!-- Category -->
                            <span class="badge badge-info align-self-start mb-2 px-3 py-2">

                                @item.Category

                            </span>

                            <!-- Name -->
                            <h5 class="font-weight-bold mb-2">

                                <a asp-controller="Product"
                                   asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="text-dark text-decoration-none">

                                    @item.Name

                                </a>

                            </h5>

                            <!-- Description -->
                            <p class="text-muted small flex-grow-1">

                                @(string.IsNullOrEmpty(item.Description)
                                                            ? "No description available."
                                                            : item.Description.Length > 90
                                                            ? item.Description.Substring(0, 90) + "..."
                                                            : item.Description)

                        </p>

                                <!-- Price -->
                                <div class="d-flex justify-content-between align-items-center mb-3">

                                    <h4 class="text-primary font-weight-bold mb-0">

                                        $@item.Price

                                    </h4>

                            @if (item.Stock > 0)
                                    {
                                        <span class="badge badge-success px-3 py-2">

                                            In Stock

                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-danger px-3 py-2">

                                            Out Of Stock

                                        </span>
                                    }

                                </div>

                                <!-- Stock -->
                                <p class="small text-muted mb-3">

                                    <i class="fa fa-cubes mr-1"></i>

                                    Available Quantity:
                                    <strong>@item.Stock</strong>

                                </p>

                                <!-- Buttons -->
                                <div class="mt-auto">

                                    <div class="d-flex flex-wrap gap-2">

                                        <!-- Details -->
                                        <a asp-controller="Product"
                                           asp-action="Details"
                                           asp-route-id="@item.Id"
                                           class="btn btn-outline-primary btn-sm flex-fill">

                                            <i class="fa fa-eye mr-1"></i>
                                            Details

                                        </a>

                                        <!-- Add To Cart -->
                                        @if (item.Stock > 0)
                                        {
                                            <a asp-controller="Order"
                                               asp-action="AddToShoppingCart"
                                               asp-route-id="@item.Id"
                                               class="btn btn-primary btn-sm flex-fill">

                                                <i class="fa fa-shopping-cart mr-1"></i>
                                                Add To Cart

                                            </a>
                                        }
                                        else
                                        {
                                            <button class="btn btn-danger btn-sm flex-fill"
                                                    disabled>

                                                Out Of Stock

                                            </button>
                                        }

                                    </div>

                                    <!-- Admin Buttons -->
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <div class="d-flex flex-wrap gap-2 mt-2">

                                            <!-- Edit -->
                                            <a asp-controller="Product"
                                               asp-action="Edit"
                                               asp-route-id="@item.Id"
                                               class="btn btn-warning btn-sm flex-fill">

                                                <i class="fa fa-edit mr-1"></i>
                                                Edit

                                            </a>

                                            <!-- Delete -->
                                            <form asp-controller="Product"
                                                  asp-action="Delete"
                                                  asp-route-id="@item.Id"
                                                  method="post"
                                                  class="flex-fill"
                                                  onsubmit="return confirm('Are you sure you want to delete this product?')">

                                                @Html.AntiForgeryToken()

                                                <button type="submit"
                                                        class="btn btn-danger btn-sm w-100">

                                                    <i class="fa fa-trash mr-1"></i>
                                                    Delete

                                                </button>

                                            </form>

                                        </div>
                                    }

                                </div>

                            </div>

                        </div>

                    </div>
                }
            }
            else
            {
                <div class="col-12">

                    <div class="alert alert-warning text-center shadow-sm">

                        <h5 class="mb-1">
                            No Products Available
                        </h5>

                        <p class="mb-0">
                            Products will appear here soon.
                        </p>

                    </div>

                </div>
            }

        </div>

    </div>

</div>

<style>

    .product-card {
        transition: 0.3s ease;
    }

        .product-card:hover {
            transform: translateY(-5px);
        }

    .gap-2 {
        gap: .5rem;
    }

</style>