@model IEnumerable<Product>

@{
    ViewData["Title"] = "المتجر الطبي";
}

<!-- شريط التنقل (Breadcrumb) -->
<div class="bg-light py-3 border-bottom text-right">
    <div class="container">
        <div class="row">
            <div class="col-md-12 mb-0">
                <a asp-controller="Home" asp-action="Index" class="text-primary font-weight-bold">الرئيسية</a>
                <span class="mx-2 text-muted">/</span>
                <strong class="text-dark">المتجر</strong>
            </div>
        </div>
    </div>
</div>

<!-- كود المتجر الرئيسي -->
<div class="site-section bg-light text-right">
    <div class="container py-4">

        <!-- الهيدر والأزرار العلوية -->
        <div class="row align-items-center mb-5">
            <div class="col-md-6 mb-3 mb-md-0">
                <h2 class="font-weight-bold text-black mb-1">صيدلية المتجر المتكاملة</h2>
                <p class="text-muted mb-0">تصفح الأدوية، الفيتامينات، ومنتجات الرعاية الصحية المعتمدة.</p>
            </div>
            <div class="col-md-6 text-md-left">
                <!-- زر رفع الروشتة -->
                <a asp-controller="Prescription" asp-action="Upload" class="btn btn-outline-primary ml-2 shadow-sm rounded-pill py-2 font-weight-bold">
                    <i class="fa fa-file-medical ml-2"></i> رفع روشتة طبية
                </a>

                <!-- زر إضافة منتج للـ Admin -->
                @if (User.IsInRole("Admin"))
                {
                    <a asp-controller="Product" asp-action="Create" class="btn btn-success shadow-sm rounded-pill py-2 font-weight-bold">
                        <i class="fa fa-plus ml-2"></i> إضافة منتج جديد
                    </a>
                }
            </div>
        </div>

        <!-- قائمة المنتجات -->
        <div class="row">
            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    <div class="col-md-6 col-lg-4 mb-4">
                        <div class="card border-0 shadow-sm h-100 rounded-lg overflow-hidden product-card bg-white p-3 custom-card-hover d-flex flex-column">

                            <!-- صورة المنتج -->
                            <div class="text-center bg-white p-2 position-relative">
                                <a asp-controller="Product" asp-action="Details" asp-route-id="@item.Id" class="d-block">
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@Url.Content(item.ImageUrl)" class="img-fluid rounded" style="height:220px; object-fit:contain;" />
                                    }
                                    else
                                    {
                                        <img src="~/images/no-image.png" class="img-fluid rounded" style="height:220px; object-fit:contain;" />
                                    }
                            </a>
                        </div>

                        <!-- تفاصيل المنتج داخل الـ Card Body -->
                        <div class="card-body p-2 d-flex flex-column flex-grow-1 text-right mt-3">
                            <!-- التصنيف أو القسم -->
                            <span class="badge badge-info align-self-start mb-2 px-3 py-2 rounded-pill font-weight-bold text-white shadow-sm">
                                @item.Category
                            </span>

                            <!-- اسم المنتج -->
                            <h5 class="font-weight-bold text-dark mb-2">
                                <a asp-controller="Product" asp-action="Details" asp-route-id="@item.Id" class="text-dark text-decoration-none transform-link">
                                    @item.Name
                                </a>
                            </h5>

                            <!-- وصف قصير للمنتج -->
                            <p class="text-muted small flex-grow-1 mb-3">
                                @(string.IsNullOrEmpty(item.Description)
                                                            ? "لا يوجد وصف متوفر لهذا المنتج الطبي حالياً."
                                                            : item.Description.Length > 85
                                                            ? item.Description.Substring(0, 85) + "..."
                                                            : item.Description)
                        </p>

                                <!-- السعر وحالة المخزن -->
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h4 class="text-primary font-weight-bold mb-0">$@item.Price</h4>
                            @if (item.Stock > 0)
                                    {
                                        <span class="badge badge-success px-3 py-2 rounded-pill font-weight-bold">متوفر بالمخزن</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-danger px-3 py-2 rounded-pill font-weight-bold">غير متوفر حالياً</span>
                                    }
                                </div>

                                <!-- الكمية المتاحة -->
                                <p class="small text-muted mb-3 border-top pt-2">
                                    <i class="fa fa-cubes ml-1 text-primary"></i> الكمية المتاحة: <strong class="text-dark">@item.Stock</strong>
                                </p>

                                <!-- أزرار التحكم والعمليات -->
                                <div class="mt-auto">
                                    <div class="d-flex gap-2">
                                        <!-- زر التفاصيل -->
                                        <a asp-controller="Product" asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm flex-fill rounded-pill font-weight-bold shadow-sm py-2 ml-1">
                                            <i class="fa fa-eye ml-1"></i> التفاصيل
                                        </a>

                                        <!-- زر الشراء -->
                                        @if (item.Stock > 0)
                                        {
                                            <a asp-controller="Order" asp-action="AddToShoppingCart" asp-route-id="@item.Id" class="btn btn-primary btn-sm flex-fill rounded-pill font-weight-bold shadow-sm py-2">
                                                <i class="fa fa-shopping-cart ml-1"></i> أضف للسلة
                                            </a>
                                        }
                                        else
                                        {
                                            <button class="btn btn-secondary btn-sm flex-fill rounded-pill font-weight-bold py-2" disabled>نفذت الكمية</button>
                                        }
                                    </div>

                                    <!-- لوحة تحكم الأدمن (تعديل وحذف) -->
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <div class="d-flex gap-2 mt-2 pt-2 border-top">
                                            <a asp-controller="Product" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm flex-fill rounded-pill font-weight-bold text-dark ml-1">
                                                <i class="fa fa-edit ml-1"></i> تعديل
                                            </a>
                                            <form asp-controller="Product" asp-action="Delete" asp-route-id="@item.Id" method="post" class="flex-fill" onsubmit="return confirm('هل أنت متأكد تماماً من رغبتك في حذف هذا المنتج من النظام؟')">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-danger btn-sm w-100 rounded-pill font-weight-bold">
                                                    <i class="fa fa-trash ml-1"></i> حذف
                                                </button>
                                            </form>
                                        </div>
                                    }
                                </div>

                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <div class="alert alert-warning shadow-sm rounded-lg max-width-md mx-auto py-4">
                        <h5 class="font-weight-bold mb-2"><i class="fa fa-exclamation-triangle ml-2"></i> لا توجد منتجات معروضة</h5>
                        <p class="mb-0 text-secondary">سيتم إدراج الأدوية والمستلزمات في هذا القسم قريباً جداً.</p>
                    </div>
                </div>
            }
        </div>

    </div>
</div>