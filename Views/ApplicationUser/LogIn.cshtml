@using ePharma_asp_mvc.Data.ViewModels;
@model LogInViewModel;

@{
    ViewData["Title"] = "Log in your account";
}

<style>
    .login-container {
        background: #ffffff; /* أبيض صريح عشان ينطق مع الـ Theme */
        border-radius: 15px;
        padding: 30px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        border: 1px solid #eee;
    }

    .card-header {
        border-radius: 10px 10px 0 0 !important;
        text-align: center;
    }
</style>

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-5">

            @* عرض رسائل الخطأ بشكل احترافي *@
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <strong>Sorry!</strong> @TempData["Error"]
                    <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
            }

            <div class="login-container">
                <div class="card-header bg-primary text-white mb-4">
                    <h4 class="mb-0"><i class="icon-lock_outline mr-2"></i>LogIn</h4>
                </div>

                <div class="card-body p-0">
                    <form asp-action="LogIn" method="post">
                        @* ملخص الأخطاء *@
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="form-group">
                            <label asp-for="EmailAddress" class="text-black font-weight-bold">Email Address</label>
                            <input asp-for="EmailAddress" class="form-control" placeholder="Enter your email" required>
                            <span asp-validation-for="EmailAddress" class="text-danger small"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Password" class="text-black font-weight-bold">Password</label>
                            @* تعديل نوع الـ Input لباسورد *@
                            <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" required>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="mt-4">
                            <button type="submit" class="btn btn-primary btn-lg btn-block shadow-sm">Log In</button>
                        </div>
                    </form>

                    <div class="text-center mt-4">
                        <p class="text-muted small">Don't have an account?</p>
                        <a class="btn btn-outline-primary btn-block" asp-controller="ApplicationUser" asp-action="SignUp">Create New Account</a>
                    </div>

                    <div class="text-center mt-3">
                        <a asp-controller="Home" asp-action="Index" class="text-primary small"><i class="icon-arrow-left mr-1"></i> Back to Home</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<br />