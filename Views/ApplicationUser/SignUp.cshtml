@using ePharma_asp_mvc.Data.ViewModels;
@model SignUpViewModel;

@{
    ViewData["Title"] = "إنشاء حساب جديد";
}

<div class="container mt-5 mb-5" dir="rtl">
    <div class="row justify-content-center">
        <div class="col-md-9 col-lg-7">

            @* عرض أخطاء السيرفر إن وجدت *@
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm text-right" role="alert">
                    <i class="fas fa-exclamation-circle ml-2"></i><strong>عذراً!</strong> @TempData["Error"]
                    <button type="button" class="close mr-auto ml-0" data-dismiss="alert" style="right: auto; left: 15px;">&times;</button>
                </div>
            }

            @* حاوية التسجيل الفاخرة *@
            <div class="signup-container bg-white shadow-sm border rounded-3 p-4 text-right">
                <div class="card-header-custom bg-primary text-white mb-4 text-center rounded p-3 shadow-sm">
                    <h4 class="mb-0 fw-bold"><i class="fas fa-user-plus ml-2"></i>إنشاء حساب جديد في الصيدلية</h4>
                </div>

                <form asp-action="SignUp" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <!-- الاسم الأول والاسم الأخير في سطر واحد متناسق RTL -->
                    <div class="row">
                        <div class="col-md-6 form-group mb-3">
                            <label asp-for="FirstName" class="text-dark fw-bold mb-2">الاسم الأول</label>
                            <input asp-for="FirstName" class="form-control text-right" placeholder="مثال: أحمد">
                            <span asp-validation-for="FirstName" class="text-danger small d-block mt-1"></span>
                        </div>
                        <div class="col-md-6 form-group mb-3">
                            <label asp-for="LastName" class="text-dark fw-bold mb-2">اسم العائلة</label>
                            <input asp-for="LastName" class="form-control text-right" placeholder="مثال: محمد">
                            <span asp-validation-for="LastName" class="text-danger small d-block mt-1"></span>
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="UserName" class="text-dark fw-bold mb-2">اسم المستخدم (Username)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-left-0 rounded-right-custom"><i class="fas fa-at text-muted"></i></span>
                            <input asp-for="UserName" class="form-control border-right-0 rounded-left-custom text-left" dir="ltr" placeholder="ahmed_123">
                        </div>
                        <span asp-validation-for="UserName" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="EmailAddress" class="text-dark fw-bold mb-2">البريد الإلكتروني</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-left-0 rounded-right-custom"><i class="fas fa-envelope text-muted"></i></span>
                            <input asp-for="EmailAddress" type="email" class="form-control border-right-0 rounded-left-custom text-left" dir="ltr" placeholder="name@example.com">
                        </div>
                        <span asp-validation-for="EmailAddress" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="PhoneNumber" class="text-dark fw-bold mb-2">رقم الهاتف الذكي</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-left-0 rounded-right-custom"><i class="fas fa-phone text-muted"></i></span>
                            <input asp-for="PhoneNumber" type="tel" class="form-control border-right-0 rounded-left-custom text-left" dir="ltr" placeholder="01xxxxxxxxx">
                        </div>
                        <span asp-validation-for="PhoneNumber" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Address" class="text-dark fw-bold mb-2">عنوان التوصيل الافتراضي</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-left-0 rounded-right-custom"><i class="fas fa-map-marker-alt text-muted"></i></span>
                            <input asp-for="Address" class="form-control border-right-0 rounded-left-custom text-right" placeholder="المحافظة، المدينة، الشارع، رقم المبنى">
                        </div>
                        <span asp-validation-for="Address" class="text-danger small d-block mt-1"></span>
                    </div>

                    <!-- كلمات المرور -->
                    <div class="row">
                        <div class="col-md-6 form-group mb-3">
                            <label asp-for="Password" class="text-dark fw-bold mb-2">كلمة المرور</label>
                            <input asp-for="Password" type="password" class="form-control text-right" placeholder="••••••••">
                            <span asp-validation-for="Password" class="text-danger small d-block mt-1"></span>
                        </div>
                        <div class="col-md-6 form-group mb-3">
                            <label asp-for="ConfirmPassword" class="text-dark fw-bold mb-2">تأكيد كلمة المرور</label>
                            <input asp-for="ConfirmPassword" type="password" class="form-control text-right" placeholder="••••••••">
                            <span asp-validation-for="ConfirmPassword" class="text-danger small d-block mt-1"></span>
                        </div>
                    </div>

                    <!-- صندوق التلميحات المحسن هندسياً وبصرياً -->
                    <div class="password-hint mb-4 p-3 rounded shadow-sm text-right d-flex align-items-start">
                        <i class="fas fa-info-circle text-info ml-2 mt-1"></i>
                        <p class="mb-0 small text-secondary">
                            <strong>اشتراطات الأمان:</strong> يجب ألا تقل عن 6 خانات، وتحتوي على رقم واحد على الأقل، وحرف كبير (Uppercase)، وحرف صغير (Lowercase)، ورمز خاص واحد مثل (#، $، !).
                        </p>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100 shadow-sm fw-bold py-2">تأكيد وإنشاء الحساب</button>
                </form>

                <div class="text-center mt-4 border-top pt-3">
                    <p class="text-muted small">لديك حساب بالفعل؟ <a asp-action="LogIn" class="text-primary fw-bold text-decoration-none">تسجيل الدخول مباشرة</a></p>
                </div>
            </div>

        </div>
    </div>
</div>

<style>
    .signup-container {
        border-radius: 16px !important;
        border: 1px solid rgba(0, 0, 0, 0.05) !important;
    }

    .card-header-custom {
        background: linear-gradient(135deg, #007bff, #0056b3);
    }

    .rounded-right-custom {
        border-top-right-radius: 8px !important;
        border-bottom-right-radius: 8px !important;
        border-top-left-radius: 0 !important;
        border-bottom-left-radius: 0 !important;
    }
       
    .rounded-left-custom {
        border-top-left-radius: 8px !important;
        border-bottom-left-radius: 8px !important;
        border-top-right-radius: 0 !important;
        border-bottom-right-radius: 0 !important;
    }

    .password-hint {
        background-color: #f0f7ff;
        border-right: 4px solid #17a2b8;
        border-left: none !important;
    }
</style>