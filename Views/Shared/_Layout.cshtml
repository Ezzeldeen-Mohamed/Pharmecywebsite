<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - صيدلية د. محمد عبدالله الشنواني</title>

    <!-- إضافة أيقونة سماعة الدكتور (Favicon) لتبويب المتصفح العلوي -->
    <link rel="icon" type="image/png" href="https://img.icons8.com/fluent/48/stethoscope.png" />
    <!-- Bootstrap 5 RTL لضمان انضباط الاتجاهات -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css">

    <!-- ملفات الـ Styles الأساسية للمشروع -->
    <link href="~/fonts/icomoon/style.css" rel="stylesheet" />
    <link href="~/css/magnific-popup.css" rel="stylesheet" />
    <link href="~/css/jquery-ui.css" rel="stylesheet" />
    <link href="~/css/owl.carousel.min.css" rel="stylesheet" />
    <link href="~/css/owl.theme.default.min.css" rel="stylesheet" />
    <link href="~/css/aos.css" rel="stylesheet" />
    <link href="~/css/style.css" rel="stylesheet" />

    <!-- الخطوط والأيقونات الممتازة -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        /* نظام الـ Typography والـ Theme الفاخر */
        body {
            font-family: 'Cairo', sans-serif;
            background-color: #f8fafc;
            color: #1e293b;
            overflow-x: hidden;
        }

        /* الـ Navbar المطور بتقنية الشفافية الزجاجية */
        .site-navbar {
            background: rgba(255, 255, 255, 0.95) !important;
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(241, 245, 249, 0.8);
            box-shadow: 0 4px 20px rgba(15, 23, 42, 0.03);
            transition: all 0.3s ease;
        }

        /* الهيكل الدقيق لشعار الصيدلية الجديد */
        .pharmacy-brand-wrapper {
            display: flex;
            flex-direction: column;
            text-decoration: none !important;
            line-height: 1.3;
        }

        .pharmacy-main-title {
            font-size: 1.1rem;
            font-weight: 800;
            color: #0284c7; /* لون طبي ذكي */
            transition: color 0.3s ease;
        }

        .pharmacy-main-title i {
            color: #10b981; /* الزمرد الطبي لإعطاء لمسة حيوية */
        }

        .pharmacy-sub-title {
            font-size: 0.82rem;
            font-weight: 600;
            color: #64748b;
            padding-right: 2px;
        }

        /* حركات تفاعلية متطورة للقائمة العلوية (Advanced Hover FX) */
        .site-menu li a {
            font-weight: 700 !important;
            color: #475569 !important;
            font-size: 0.95rem;
            position: relative;
            padding: 10px 15px !important;
            transition: color 0.3s ease !important;
            display: block;
        }

            .site-menu li a:hover, .site-menu li.active a {
                color: #0284c7 !important;
                background-color: rgba(2, 132, 199, 0.05);
                border-radius: 8px;
            }

        .site-menu li a:hover::after, .site-menu li.active a::after {
            width: 80%;
            left: 10%;
        }

        }

        .site-menu li a:hover, .site-menu li.active a {
            color: #0284c7 !important;
            background-color: rgba(2, 132, 199, 0.05);
            border-radius: 8px;
        }

            .site-menu li a:hover::after, .site-menu li.active a::after {
                width: 80%;
                left: 10%;
            }

        } /* <-- القوس ده ملوش قفلة فوق وسايب برضه Error خفي */

        /* تعديل أدوات الأيقونات (البحث والسلة والواتساب) */
        .icons-btn {
            color: #475569 !important;
            font-size: 1.1rem;
            transition: all 0.2s ease;
            padding: 6px;
            border-radius: 10px;
        }

            .icons-btn:hover {
                color: #0284c7 !important;
                background: rgba(2, 132, 199, 0.08);
            }

        /* لمسة خاصة لأيقونة الواتساب في الهيدر */
        .whatsapp-nav-btn:hover {
            color: #25d366 !important;
            background: rgba(37, 211, 102, 0.1);
        }

        /* تعديل زر القائمة المنسدلة للموبايل */
        .navbar-toggler {
            border: none;
            padding: 6px;
            color: #475569;
        }

            .navbar-toggler:focus {
                box-shadow: none;
                background: rgba(2, 132, 199, 0.08);
            }

        /* البانرات الإعلانية الفاخرة (Advanced Section Cards) */
        .advanced-banner-card {
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.4s ease;
            border: 1px solid rgba(255,255,255,0.7);
        }

            .advanced-banner-card:hover {
                transform: translateY(-8px);
                box-shadow: 0 20px 40px rgba(0,0,0,0.12);
            }

        .banner-overlay-dark {
            background: linear-gradient(135deg, rgba(15, 23, 42, 0.85), rgba(15, 23, 42, 0.4));
            width: 100%;
            padding: 40px;
            border-radius: 20px;
        }

        /* تزيين الـ Footer المطور */
        .site-footer {
            background-color: #0f172a !important;
            color: #94a3b8 !important;
            padding: 5em 0 3em 0 !important;
        }

            .site-footer h3 {
                color: #f8fafc !important;
                font-weight: 700;
                font-size: 1.15rem;
                border-right: 3px solid #10b981;
                padding-right: 10px;
            }

            .site-footer a {
                color: #cbd5e1 !important;
                transition: all 0.2s ease;
                text-decoration: none;
            }

                .site-footer a:hover {
                    color: #10b981 !important;
                    padding-right: 4px;
                }

        /* زر الواتساب العائم الاحترافي */
        .whatsapp-floating-btn {
            position: fixed;
            bottom: 30px;
            left: 30px;
            background-color: #25d366;
            color: #fff !important;
            width: 55px;
            height: 55px;
            border-radius: 50px;
            text-align: center;
            font-size: 28px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
        }

            .whatsapp-floating-btn:hover {
                transform: scale(1.1);
                background-color: #20ba5a;
                box-shadow: 0 6px 20px rgba(37, 211, 102, 0.4);
            }
    </style>
</head>
<body>
    <div class="site-wrap">

        <!-- الـ Navbar الرئيسي للبراند يدعم التجاوب بالكامل -->
        <nav class="navbar navbar-expand-lg site-navbar py-3 sticky-top">
            <!-- شريط البحث المنسدل الفاخر -->
            <div class="search-wrap">
                <div class="container">
                    <a href="#" class="search-close js-search-close"><span class="icon-close2"></span></a>
                    <form asp-controller="Home" asp-action="Search" method="post">
                        <input type="text" name="searchString" class="form-control text-right" placeholder="اكتب اسم المنتج الدوائي أو المستحضر واضغط Enter...">
                    </form>
                </div>
            </div>

            <div class="container">
                <!-- الهوية والشعار هيدر -->
                <a asp-controller="Home" asp-action="Index" class="pharmacy-brand-wrapper">
                    <span class="pharmacy-main-title">
                        <i class="fas fa-prescription-bottle-alt me-1"></i> صيدلية د. محمد عبدالله الشنواني
                    </span>
                    <span class="pharmacy-sub-title">
                        <i class="fas fa-user-md me-1"></i> إدارة د. عمر محمد
                    </span>
                </a>

                <!-- أزرار التحكم الجانبية (البحث، السلة، الهامبرجر منيو للموبايل) -->
                <div class="d-flex align-items-center gap-1 order-lg-last">
                    <a href="https://wa.me/201001193397?text=السلام%20عليكم،%20أريد%20إستشارة%20طبية" target="_blank" class="icons-btn whatsapp-nav-btn" title="استشارة واتساب">
                        <i class="fab fa-whatsapp"></i>
                    </a>

                    <a href="#" class="icons-btn js-search-open"><span class="icon-search"></span></a>

                    <!-- مكون سلة المشتريات المدمج الديناميكي -->
                    @await Component.InvokeAsync("ShoppingCartCount")

                    <!-- زر الموبايل التفاعلي الجديد (Hamburger Menu) -->
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainPharmacyNav" aria-controls="mainPharmacyNav" aria-expanded="false" aria-label="Toggle navigation">
                        <i class="fas fa-bars fs-4"></i>
                    </button>
                </div>

                <!-- القائمة المنسدلة (تتحول لقائمة برجر على الموبايل وتفرد تلقائياً على الشاشات الكبيرة) -->
                <div class="collapse navbar-collapse mt-3 mt-lg-0" id="mainPharmacyNav">
                    <ul class="navbar-nav site-menu me-auto mb-2 mb-lg-0 gap-lg-2 p-0 text-right">
                        <li class="@(ViewData["Title"]?.ToString() == "الرئيسية" ? "active" : "")"><a asp-controller="Home" asp-action="Index">الرئيسية</a></li>
                        <li class="@(ViewData["Title"]?.ToString() == "المتجر الدوائي" ? "active" : "")"><a asp-controller="Home" asp-action="Shop">المتجر الدوائي</a></li>
                        <li class="@(ViewData["Title"]?.ToString() == "الخدمات الطبية" ? "active" : "")"><a asp-controller="HealthServices" asp-action="Index">الخدمات الطبية</a></li>
                        <li class="@(ViewData["Title"]?.ToString() == "عن الصيدلية" ? "active" : "")"><a asp-controller="Home" asp-action="About">عن الصيدلية</a></li>

                        <!-- عنصر الهوية والـ Dropdown -->
                        <partial name="_Identity.cshtml"></partial>
                    </ul>
                </div>

            </div>
        </nav>

        <!-- الجزء الديناميكي لعرض محتوى الصفحات الداخلية -->
        <main role="main">
            @RenderBody()
        </main>

        <!-- قسم العروض والمميزات (Premium Banner View) -->
        <div class="site-section bg-light py-5">
            <div class="container">
                <div class="row align-items-stretch g-4">
                    <div class="col-lg-6">
                        <div class="advanced-banner-card d-flex h-100" style="background: url('../images/bg_1.jpg') center/cover no-repeat;">
                            <div class="banner-overlay-dark d-flex flex-column justify-content-center text-white h-100">
                                <h2 class="fw-bold mb-3"><i class="fas fa-mortar-pestle text-success me-2"></i> المنتجات الطبية والرعاية</h2>
                                <p class="opacity-85 fs-6">
                                    نوفر لكم باقة متكاملة من الأدوية الأصلية ومستحضرات التجميل العالمية الخاضعة للرقابة الصحية الدقيقة والموثوقة.
                                </p>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-6">
                        <div class="advanced-banner-card d-flex h-100" style="background: url('../images/bg_2.jpg') center/cover no-repeat;">
                            <div class="banner-overlay-dark d-flex flex-column justify-content-center text-white h-100">
                                <h2 class="fw-bold mb-3"><i class="fas fa-award text-info me-2"></i> تقييم الخبراء والأطباء</h2>
                                <p class="opacity-85 fs-6">
                                    خدمات استشارية ودوائية متميزة تحت إشراف نخبة من الصيادلة المتخصصين لضمان تقديم أعلى مستويات الرعاية الصحية لك ولعائلتك.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- الـ Footer الاحترافي الجديد بالكامل -->
        <footer class="site-footer">
            <div class="container">
                <div class="row g-5">
                    <div class="col-md-6 col-lg-4">
                        <div class="block-7">
                            <h3 class="mb-4">عن صيدليتنا</h3>
                            <p class="lh-lg opacity-75">
                                صيدلية الدكتور محمد عبدالله الشنواني (تحت إدارة د. عمر محمد) تسعى دائماً لتقديم منظومة رعاية صحية متكاملة، عبر توفير الخدمات الدوائية والاستشارات الطبية وتوصيل الطلبات بكل دقة وسرعة.
                            </p>
                        </div>
                    </div>
                    <div class="col-lg-4 mx-auto">
                        <h3 class="mb-4">روابط سريعة</h3>
                        <ul class="list-unstyled d-flex flex-column gap-2 p-0">
                            <li><a asp-controller="Home" asp-action="Shop"><i class="fas fa-chevron-left me-2 text-success fs-7"></i> المتجر الدوائي الرئيسي</a></li>
                            <li><a asp-controller="HealthServices" asp-action="Index"><i class="fas fa-chevron-left me-2 text-success fs-7"></i> الخدمات والاستشارات</a></li>
                            <li><a asp-controller="Home" asp-action="About"><i class="fas fa-chevron-left me-2 text-success fs-7"></i> فريق العمل وقصة البداية</a></li>
                        </ul>
                    </div>
                    <div class="col-md-6 col-lg-4">
                        <div class="block-5">
                            <h3 class="mb-4 text-white">بيانات التواصل المباشر</h3>
                            <ul class="list-unstyled d-flex flex-column gap-3 p-0 opacity-85">
                                <li class="d-flex align-items-start gap-2 text-white">
                                    <i class="fas fa-map-marker-alt text-danger mt-1"></i>
                                    <span>جمهورية مصر العربية، قرية سندبسط / محافظة الغربية</span>
                                </li>
                                <li class="d-flex align-items-center gap-2">
                                    <i class="fas fa-phone-alt text-success"></i>
                                    <a href="tel:+201001193397" dir="ltr" class="text-white">
                                        +20 100 119 3397
                                    </a>
                                </li>
                                <li class="d-flex align-items-center gap-2">
                                    <i class="fab fa-whatsapp text-success fs-5"></i>
                                    <a href="https://wa.me/201001193397?text=السلام%20عليكم،%20أريد%20إستشارة%20طبية" target="_blank" class="text-white fw-bold">
                                        إستشارة عبر الواتساب المباشر
                                    </a>
                                </li>
                                <li class="d-flex align-items-center gap-2">
                                    <i class="fab fa-facebook text-primary"></i>
                                    <a href="https://www.facebook.com/profile.php?id=61556042277255" target="_blank" class="text-white">
                                        Facebook Profile
                                    </a>
                                </li>
                                <li class="d-flex align-items-center gap-2 text-white">
                                    <i class="fas fa-envelope text-info"></i>
                                    <span>omarmuhamed176@gmail.com</span>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="row pt-5 mt-5 border-top border-secondary text-center opacity-75">
                    <div class="col-md-12 d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
                        <p class="m-0 text-white">
                            حقوق الطبع والنشر محفوظة &copy; @DateTime.Now.Year | صيدلية د. محمد عبدالله الشنواني
                        </p>
                        <p class="m-0 small">
                            تطوير وهندسة الأنظمة:
                            <a href="https://ezzeldeenmohamed.netlify.app" target="_blank" class="text-info fw-bold text-decoration-underline ms-1">
                                م. عز الدين محمد <i class="fas fa-globe"></i>
                            </a>
                        </p>
                    </div>
                </div>
            </div>
        </footer>

        <!-- الزر العائم للواتساب -->
        <a href="https://wa.me/201001193397?text=السلام%20عليكم،%20أريد%20إستشارة%20طبية" class="whatsapp-floating-btn" target="_blank" title="تواصل معنا مباشرة عبر واتساب">
            <i class="fab fa-whatsapp"></i>
        </a>

        <!-- ملفات الـ JavaScript -->
        <script src="~/js/jquery-3.3.1.min.js"></script>
        <script src="~/js/jquery-ui.js"></script>
        <script src="~/js/popper.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        <script src="~/js/owl.carousel.min.js"></script>
        <script src="~/js/jquery.magnific-popup.min.js"></script>
        <script src="~/js/aos.js"></script>
        <script src="~/js/main.js"></script>

        @await RenderSectionAsync("Scripts", required: false)

    </div>
</body>
</html>