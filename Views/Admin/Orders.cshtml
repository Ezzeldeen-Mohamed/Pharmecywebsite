@using ePharma_asp_mvc.Models.Enums;
@model IEnumerable<Order>

@{
    ViewData["Title"] = "Customer Orders";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-1 text-dark fw-bold"><i class="fas fa-shopping-basket text-primary me-2"></i>Customer Orders Management</h3>
            <p class="text-muted small mb-0">Monitor payments, dispatch updates, and trace delivery statuses dynamically.</p>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light border-bottom">
                        <tr>
                            <th class="ps-4" style="width: 12%">Order ID</th>
                            <th style="width: 25%">Customer</th>
                            <th style="width: 18%">Date Ordered</th>
                            <th style="width: 15%">Total Amount</th>
                            <th style="width: 15%">Status</th>
                            <th class="text-end pe-4" style="width: 15%">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="fas fa-box-open fa-3x mb-3 d-block text-secondary"></i>
                                    No customer orders placed yet.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var order in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-secondary">#@order.Id</td>
                                    <td>
                                        <span class="d-block fw-bold text-dark">@(order.User != null ? $"{order.User.FirstName} {order.User.LastName}" : "Unknown Customer")</span>
                                        <small class="text-muted d-block text-truncate" style="max-width: 220px;">@(order.User?.Email ?? "No Email Registered")</small>
                                    </td>
                                    <td class="text-muted small">
                                        @order.TimeOrdered.ToString("dd MMM yyyy, hh:mm tt")
                                    </td>
                                    <td class="fw-bold text-primary">
                                        @order.TotalPrice.ToString("C2")
                                    </td>
                                    <td>
                                        @{
                                            var statusBadge = order.Status switch
                                            {
                                                OrderStatus.Pending => "bg-warning text-dark",
                                                OrderStatus.Accepted => "bg-info text-white", // أو Processing حسب اختيارك لخطوط النقل
                                                OrderStatus.Completed => "bg-success text-white",
                                                OrderStatus.Cancelled => "bg-danger text-white",
                                                _ => "bg-dark text-white"
                                            };
                                        }
                                        <span class="badge @statusBadge px-3 py-2 rounded-pill" style="font-size: 0.8rem; min-width: 105px; text-align: center;">
                                            <i class="fas fa-circle me-1" style="font-size: 7px; vertical-align: middle;"></i> @order.Status
                                        </span>
                                    </td>
                                    <td class="text-end pe-4">
                                        <!-- زر توجيهي إلى صفحة الفاتورة وإدارة الطلب النهائي -->
                                        <a asp-action="OrderDetails" asp-controller="Admin" asp-route-id="@order.Id" class="btn btn-sm btn-dark px-3 rounded-pill shadow-sm" title="Manage Order Logistics">
                                            <i class="fas fa-sliders-h me-1"></i> Manage
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>