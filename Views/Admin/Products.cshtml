@model IEnumerable<Product>

@{
    ViewData["Title"] = "إدارة الأجهزة والمخزون";
}

<div class="container py-4" dir="rtl">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-row-reverse">
        <a asp-controller="Product" asp-action="Create" class="btn btn-primary shadow-sm">
            <i class="fas fa-plus ml-1"></i> إضافة منتج جديد
        </a>
        <h3 class="text-dark text-right mb-0"><i class="fas fa-pills ml-2 text-primary"></i>إدارة المخزون والأدوية</h3>
    </div>

    <!-- عرض المنتجات بأسلوب كروت الـ Grid الفاخرة المنسقة والمصلحة هيكلياً -->
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4 text-right">
        @foreach (var item in Model)
        {
            <div class="col mb-4">
                <div class="card shadow-sm border-0 h-100 card-product">
                    <div class="position-relative text-center p-3 bg-light rounded-top">
                        <img src="@item.ImageUrl" class="card-img-top" style="height:200px; object-fit:contain;" alt="@item.Name" />
                    </div>

                    <div class="card-body d-flex flex-column justify-content-between">
                        <div>
                            <h5 class="card-title fw-bold text-dark text-truncate">@item.Name</h5>
                            <p class="text-muted small text-truncate-2" style="height: 40px; overflow: hidden;">@item.Description</p>
                        </div>

                        <div class="mt-3">
                            <h4 class="text-primary fw-bold mb-3">@item.Price ج.م</h4>

                            <!-- أزرار التحكم والعمليات -->
                            <div class="d-flex justify-content-start gap-2 flex-wrap">
                                <a asp-controller="Product" asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary btn-sm rounded-pill px-3">
                                    تفاصيل
                                </a>

                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-controller="Product" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm rounded-pill px-3 text-white">
                                        تعديل
                                    </a>

                                    <form asp-controller="Product" asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('هل أنت متأكد تماماً من حذف هذا المنتج من المخزن؟')" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-danger btn-sm rounded-pill px-3">
                                            حذف
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .card-product {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

        .card-product:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 20px rgba(0,0,0,0.1) !important;
        }
    /* لجعل النص ينقطع بعد سطرين بسلاسة */
    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .gap-2 > * {
        margin-left: 4px;
    }
</style>