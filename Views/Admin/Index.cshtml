@{
    ViewData["Title"] = "لوحة التحكم الإدارية";
}

<div class="container-fluid py-4" dir="rtl">
    <div class="row mb-4">
        <div class="col-12 text-right">
            <h2 class="text-dark font-weight-bold">لوحة إدارة الصيدلية</h2>
            <p class="text-muted">مرحباً بك مجدداً، المدير العام. إليك تقرير سريع عن نشاط الصيدلية اليوم.</p>
        </div>
    </div>

    <!-- قسم الإحصائيات السريعة -->
    <div class="row g-4 row-cols-1 row-cols-md-2 row-cols-lg-5">
        <!-- إجمالي الإيرادات -->
        <div class="col">
            <div class="card border-0 shadow-sm bg-primary text-white h-100">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div class="d-flex justify-content-between align-items-start w-100">
                        <div class="text-right">
                            <p class="mb-1 opacity-75">إجمالي الإيرادات</p>
                            <h4 class="mb-0 font-weight-bold">$@ViewBag.TotalRevenue.ToString("N2")</h4>
                        </div>
                        <div class="icon-shape bg-white text-primary rounded-circle p-3">
                            <i class="fas fa-dollar-sign"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- إجمالي الطلبات -->
        <div class="col">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div class="d-flex justify-content-between align-items-start w-100">
                        <div class="text-right">
                            <p class="text-muted mb-1">إجمالي الطلبات</p>
                            <h4 class="mb-0 font-weight-bold">@ViewBag.TotalOrders</h4>
                        </div>
                        <div class="icon-shape bg-light text-success rounded-circle p-3">
                            <i class="fas fa-shopping-cart"></i>
                        </div>
                    </div>
                    <div class="mt-2 small text-right">
                        <span class="text-warning font-weight-bold">@ViewBag.PendingOrders في الانتظار</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- إجمالي الروشتات -->
        <div class="col">
            <div class="card border-0 shadow-sm h-100 border-right-prescription">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div class="d-flex justify-content-between align-items-start w-100">
                        <div class="text-right">
                            <p class="text-muted mb-1">الروشتات الطبية</p>
                            <h4 class="mb-0 font-weight-bold">@(((IEnumerable<ePharma_asp_mvc.Models.Prescription>)ViewBag.TotalPrescriptions).Count())</h4>
                        </div>
                        <div class="icon-shape bg-soft-purple text-purple rounded-circle p-3">
                            <i class="fas fa-file-medical"></i>
                        </div>
                    </div>
                    <div class="mt-2 small text-right">
                        <span class="text-danger font-weight-bold">@ViewBag.PendingPrescriptions جديدة</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- إجمالي الأدوية -->
        <div class="col">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div class="d-flex justify-content-between align-items-start w-100">
                        <div class="text-right">
                            <p class="text-muted mb-1">إجمالي الأدوية</p>
                            <h4 class="mb-0 font-weight-bold">@ViewBag.TotalProducts</h4>
                        </div>
                        <div class="icon-shape bg-light text-info rounded-circle p-3">
                            <i class="fas fa-pills"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- المستخدمين المسجلين -->
        <div class="col">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div class="d-flex justify-content-between align-items-start w-100">
                        <div class="text-right">
                            <p class="text-muted mb-1">المستخدمين المسجلين</p>
                            <h4 class="mb-0 font-weight-bold">@ViewBag.TotalUsers</h4>
                        </div>
                        <div class="icon-shape bg-light text-secondary rounded-circle p-3">
                            <i class="fas fa-users"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- قسم الإجراءات السريعة -->
    <div class="row mt-5" dir="rtl">
        <div class="col-12 mb-3 text-right">
            <h4 class="text-dark fw-bold">إجراءات سريعة</h4>
        </div>

        <!-- إدارة المخزون -->
        <div class="col-md-6 col-lg-3 mb-4">
            <div class="card h-100 border-0 shadow-sm text-center p-4">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div>
                        <i class="fas fa-boxes fa-3x text-primary mb-3"></i>
                        <h5 class="fw-bold">إدارة المخزون</h5>
                        <p class="text-muted small">إضافة، تحديث، أو حذف الأدوية والمستلزمات من المتجر.</p>
                    </div>
                    <a asp-action="Products" class="btn btn-outline-primary w-100 mt-3">الانتقال للأدوية</a>
                </div>
            </div>
        </div>

        <!-- تتبع الطلبات -->
        <div class="col-md-6 col-lg-3 mb-4">
            <div class="card h-100 border-0 shadow-sm text-center p-4 border-right-highlight">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div>
                        <i class="fas fa-clipboard-list fa-3x text-success mb-3"></i>
                        <h5 class="fw-bold">تتبع الطلبات</h5>
                        <p class="text-muted small">إدارة طلبات العملاء وتحديث حالات الشحن والتوصيل مباشرة.</p>
                    </div>
                    <a asp-action="Orders" asp-controller="Admin" class="btn btn-outline-success w-100 mt-3">عرض الطلبات</a>
                </div>
            </div>
        </div>

        <!-- مراجعة الروشتات -->
        <div class="col-md-6 col-lg-3 mb-4">
            <div class="card h-100 border-0 shadow-sm text-center p-4">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div>
                        <i class="fas fa-receipt fa-3x text-purple mb-3"></i>
                        <h5 class="fw-bold">طلبات الروشتات</h5>
                        <p class="text-muted small">مراجعة الصور المرفوعة للروشتات الطبية وتحويلها لطلبات فعلية.</p>
                    </div>
                    <a asp-controller="Prescription" asp-action="All" class="btn btn-outline-purple w-100 mt-3">مراجعة الروشتات</a>
                </div>
            </div>
        </div>

        <!-- طلبات الرعاية والخدمات المنزلية -->
        <div class="col-md-6 col-lg-3 mb-4">
            <div class="card h-100 border-0 shadow-sm text-center p-4">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div>
                        <i class="fas fa-hand-holding-medical fa-3x text-info mb-3"></i>
                        <h5 class="fw-bold">الخدمات الطبية</h5>
                        <p class="text-muted small">مراجعة طلبات الرعاية الصحية، الزيارات المنزلية، وخدمات التمريض.</p>
                    </div>
                    <a asp-action="AllRequests" asp-controller="HealthServices" class="btn btn-outline-info w-100 mt-3">عرض الطلبات</a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .icon-shape {
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .card {
        transition: all 0.3s ease;
    }

        .card:hover {
            transform: translateY(-5px);
        }

    .text-purple {
        color: #6f42c1 !important;
    }

    .bg-soft-purple {
        background-color: #f3e5f5;
    }

    .btn-outline-purple {
        color: #6f42c1;
        border-color: #6f42c1;
    }

        .btn-outline-purple:hover {
            background-color: #6f42c1;
            color: #fff;
        }

    /* التعديل ليتناسب مع اتجاه RTL للحدود الجانبية الملونة */
    .border-right-prescription {
        border-right: 4px solid #6f42c1 !important;
        border-left: none !important;
    }

    .border-right-highlight {
        border-right: 4px solid #28a745 !important;
        border-left: none !important;
    }
</style>