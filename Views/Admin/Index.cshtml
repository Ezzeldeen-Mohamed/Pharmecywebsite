@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="text-dark font-weight-bold">Pharmacy Management Dashboard</h2>
            <p class="text-muted">Welcome back, Admin. Here's what's happening with your pharmacy today.</p>
        </div>
    </div>

    <!-- Quick Stats Section -->
    <!-- تم تعديل الـ Row لـ col-lg-2.4 أو col-xl عشان يستوعب 5 كروت بشكل متناسق -->
    <div class="row g-4 row-cols-1 row-cols-md-2 row-cols-lg-5">
        <!-- Total Revenue -->
        <div class="col">
            <div class="card border-0 shadow-sm bg-primary text-white h-100">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="mb-1 opacity-75">Total Revenue</p>
                            <h4 class="mb-0 font-weight-bold">$@ViewBag.TotalRevenue.ToString("N2")</h4>
                        </div>
                        <div class="icon-shape bg-white text-primary rounded-circle p-3">
                            <i class="fas fa-dollar-sign"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Orders -->
        <div class="col">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-1">Total Orders</p>
                            <h4 class="mb-0 font-weight-bold">@ViewBag.TotalOrders</h4>
                        </div>
                        <div class="icon-shape bg-light text-success rounded-circle p-3">
                            <i class="fas fa-shopping-cart"></i>
                        </div>
                    </div>
                    <div class="mt-2 small">
                        <span class="text-warning font-weight-bold">@ViewBag.PendingOrders Pending</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Prescriptions (الكارت الجديد لـ إحصائيات الروشتات) -->
        <div class="col">
            <div class="card border-0 shadow-sm h-100 border-left-prescription">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-1">Prescriptions</p>
                            <h4 class="mb-0 font-weight-bold">@(((IEnumerable<ePharma_asp_mvc.Models.Prescription>)ViewBag.TotalPrescriptions).Count())</h4>
                        </div>
                        <div class="icon-shape bg-soft-purple text-purple rounded-circle p-3">
                            <i class="fas fa-file-medical"></i>
                        </div>
                    </div>
                    <div class="mt-2 small">
                        <span class="text-danger font-weight-bold">@ViewBag.PendingPrescriptions New</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Products -->
        <div class="col">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-1">Total Medicines</p>
                            <h4 class="mb-0 font-weight-bold">@ViewBag.TotalProducts</h4>
                        </div>
                        <div class="icon-shape bg-light text-info rounded-circle p-3">
                            <i class="fas fa-pills"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Users -->
        <div class="col">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-1">Registered Users</p>
                            <h4 class="mb-0 font-weight-bold">@ViewBag.TotalUsers</h4>
                        </div>
                        <div class="icon-shape bg-light text-secondary rounded-circle p-3">
                            <i class="fas fa-users"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Management Links Section -->
    <div class="row mt-5">
        <div class="col-12 mb-3">
            <h4 class="text-dark">Quick Actions</h4>
        </div>

        <!-- Inventory Management -->
        <div class="col-md-6 col-lg-3 mb-4">
            <div class="card h-100 border-0 shadow-sm text-center p-4">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div>
                        <i class="fas fa-boxes fa-3x text-primary mb-3"></i>
                        <h5>Inventory Management</h5>
                        <p class="text-muted small">Add, update, or remove medicines from your store.</p>
                    </div>
                    <a asp-action="Products" class="btn btn-outline-primary w-100 mt-3">Go to Products</a>
                </div>
            </div>
        </div>

        <!-- Orders Tracking -->
        <div class="col-md-6 col-lg-3 mb-4">
            <div class="card h-100 border-0 shadow-sm text-center p-4 border-left-highlight">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div>
                        <i class="fas fa-clipboard-list fa-3x text-success mb-3"></i>
                        <h5>Orders Tracking</h5>
                        <p class="text-muted small">Manage customer orders and update their delivery status.</p>
                    </div>
                    <a asp-action="Orders" class="btn btn-outline-success w-100 mt-3">View Orders</a>
                </div>
            </div>
        </div>

        <!-- Prescription Approvals (أكشن مراجعة وقبول الروشتات الجديد) -->
        <div class="col-md-6 col-lg-3 mb-4">
            <div class="card h-100 border-0 shadow-sm text-center p-4">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div>
                        <i class="fas fa-receipt fa-3x text-purple mb-3"></i>
                        <h5>Prescription Requests</h5>
                        <p class="text-muted small">Review uploaded user prescriptions and process them.</p>
                    </div>
                    <!-- هنا هيروح للأكشن اللي بيعرض كل الروشتات للأدمن -->
                    <a asp-controller="Prescription" asp-action="All" class="btn btn-outline-purple w-100 mt-3">Review Prescriptions</a>
                </div>
            </div>
        </div>

        <!-- Service Requests -->
        <div class="col-md-6 col-lg-3 mb-4">
            <div class="card h-100 border-0 shadow-sm text-center p-4">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div>
                        <i class="fas fa-hand-holding-medical fa-3x text-info mb-3"></i>
                        <h5>Service Requests</h5>
                        <p class="text-muted small">Review healthcare and home-visit service requests.</p>
                    </div>
                    <a asp-action="AllRequests" asp-controller="HealthServices" class="btn btn-outline-info w-100 mt-3">View Requests</a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .icon-shape {
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .card {
        transition: all 0.3s ease;
    }

        .card:hover {
            transform: translateY(-5px);
        }

    .bg-soft-success {
        background-color: #e8f5e9;
    }

    /* ستايل مخصص للون الروشتات البنفسجي المحترفين بيحبوه في الـ Dashboards */
    .text-purple {
        color: #6f42c1 !important;
    }

    .bg-soft-purple {
        background-color: #f3e5f5;
    }

    .btn-outline-purple {
        color: #6f42c1;
        border-color: #6f42c1;
    }

        .btn-outline-purple:hover {
            background-color: #6f42c1;
            color: #fff;
        }

    .border-left-prescription {
        border-left: 4px solid #6f42c1 !important;
    }

    .border-left-highlight {
        border-left: 4px solid #28a745 !important;
    }
</style>