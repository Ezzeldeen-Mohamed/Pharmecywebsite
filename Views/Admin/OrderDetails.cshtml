@using ePharma_asp_mvc.Models.Enums
@model Order

<div class="container py-5" dir="rtl">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-5 flex-row-reverse">
        <a asp-action="Index" asp-controller="Admin" class="btn btn-outline-dark shadow-sm rounded-pill px-3">
            عودة للقائمة <i class="fas fa-arrow-left mr-1"></i>
        </a>
        <div class="text-right">
            <h2 class="text-dark fw-bold mb-1">
                <i class="fas fa-receipt ml-2 text-primary"></i>
                تفاصيل الطلب رقم #@Model.Id
            </h2>
            <p class="text-muted small mb-0">مراجعة البيانات المالية وتحديث حالة الطلب اللوجستية فوراً.</p>
        </div>
    </div>

    <!-- متتبع خطوات الطلب (RTL-Friendly) -->
    <div class="card shadow-sm border-0 mb-5 py-4">
        <div class="step-wizard flex-row-reverse">
            @if (Model.Status == OrderStatus.Cancelled)
            {
                <div class="step-wizard-item cancelled-step active-step">
                    <span class="progress-count"><i class="fas fa-times"></i></span>
                    <span class="step-label">تم إلغاء الطلب</span>
                </div>
            }
            else
            {
                <div class="step-wizard-item @(Model.Status >= OrderStatus.Pending ? "active-step" : "")">
                    <span class="progress-count">1</span>
                    <span class="step-label">قيد الانتظار</span>
                </div>
                <div class="step-wizard-item @(Model.Status == OrderStatus.Accepted || Model.Status == OrderStatus.Completed ? "active-step" : "")">
                    <span class="progress-count">2</span>
                    <span class="step-label">تم القبول</span>
                </div>
                <div class="step-wizard-item @(Model.Status == OrderStatus.Completed ? "active-step" : "")">
                    <span class="progress-count">3</span>
                    <span class="step-label">مكتمل</span>
                </div>
            }
        </div>
    </div>

    <div class="row text-right">
        <!-- القائمة الجانبية للتحديث السريع (الأكشن الذكي) -->
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0 border-top border-primary border-4 h-100">
                <div class="card-body">
                    <h5 class="card-title mb-3 fw-bold text-dark">الخطوة التالية</h5>

                    <form asp-action="UpdateStatus" asp-controller="Admin" method="post" id="statusForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <input type="hidden" name="status" id="statusValue" />

                        <div class="d-grid gap-2">
                            @if (Model.Status == OrderStatus.Pending)
                            {
                                <button type="button" onclick="updateStatus('@OrderStatus.Accepted')" class="btn btn-info text-white btn-lg shadow-sm w-100 mb-2">
                                    <i class="fas fa-check ml-2"></i> قبول وتجهيز الطلب
                                </button>
                            }
                            else if (Model.Status == OrderStatus.Accepted)
                            {
                                <button type="button" onclick="updateStatus('@OrderStatus.Completed')" class="btn btn-success btn-lg shadow-sm w-100 mb-2">
                                    <i class="fas fa-check-double ml-2"></i> تعيين كطلب مكتمل
                                </button>
                            }
                            else if (Model.Status == OrderStatus.Completed)
                            {
                                <div class="alert alert-success border-0 mb-0 text-center py-3 shadow-sm">
                                    <i class="fas fa-check-circle ml-2"></i> تم تسليم الطلب بنجاح
                                </div>
                            }

                            @if (Model.Status != OrderStatus.Completed && Model.Status != OrderStatus.Cancelled)
                            {
                                <hr class="my-3 text-muted" />
                                <button type="button" class="btn btn-outline-danger btn-sm border-0 w-100" onclick="updateStatus('@OrderStatus.Cancelled')">
                                    <i class="fas fa-ban ml-1"></i> إلغاء الطلب نهائياً
                                </button>
                            }
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- البيانات الأساسية وعناصر الطلب -->
        <div class="col-md-8">
            <!-- بيانات العميل -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-dark text-white py-3 text-right">
                    <h5 class="mb-0 text-white"><i class="fas fa-user-circle ml-2"></i> بيانات العميل</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-sm-6 mb-3"><strong>الاسم بالكامل:</strong> <p class="text-muted mb-0">@(Model.User != null ? $"{Model.User.FirstName} {Model.User.LastName}" : "مستخدم زائر")</p></div>
                        <div class="col-sm-6 mb-3"><strong>البريد الإلكتروني:</strong> <p class="text-muted mb-0">@(Model.User?.Email ?? "غير متوفر")</p></div>
                        <div class="col-sm-6 mb-3"><strong>رقم الهاتف:</strong> <p class="text-muted mb-0">@(Model.User?.PhoneNumber ?? "غير متوفر")</p></div>
                        <div class="col-sm-6 mb-3"><strong>عنوان التوصيل:</strong> <p class="text-muted mb-0">@(Model.CustomAddress ?? Model.User?.Address ?? "لم يحدد عنوان")</p></div>
                    </div>
                </div>
            </div>

            <!-- المنتجات المطلوبة -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-secondary text-white py-3 text-right">
                    <h5 class="mb-0 text-white"><i class="fas fa-box-open ml-2"></i> العناصر المطلوبة</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0 text-right">
                            <thead class="table-light">
                                <tr>
                                    <th class="pr-3">الدواء / المنتج</th>
                                    <th>صورة المعاينة</th>
                                    <th>السعر</th>
                                    <th>الكمية</th>
                                    <th class="pl-3">الإجمالي الفرعي</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.OrderItems != null && Model.OrderItems.Any())
                                {
                                    foreach (var item in Model.OrderItems)
                                    {
                                        <tr>
                                            <td class="pr-3 fw-bold text-dark">@item.Product?.Name</td>
                                            <td><img src="@item.Product?.ImageUrl" width="55" height="55" class="rounded shadow-sm border" style="object-fit:cover;" /></td>
                                            <td>@item.Product?.Price.ToString("C2")</td>
                                            <td><span class="badge bg-light text-dark border">x @item.Quantity</span></td>
                                            <td class="pl-3 fw-bold text-primary">@((item.Product != null ? (item.Product.Price * item.Quantity) : 0).ToString("C2"))</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer bg-light text-left py-3">
                    <h4 class="mb-0 fw-bold">الإجمالي الكلي: <span class="text-success">@Model.TotalPrice.ToString("C2")</span></h4>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* تعديل الـ Wizard ليعمل بشكل سليم في اتجاه RTL */
    .step-wizard {
        display: flex;
        justify-content: space-between;
        position: relative;
    }

    .step-wizard-item {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        flex: 1;
        z-index: 10;
    }

        /* قلب الخط الفاصل ليناسب الـ RTL */
        .step-wizard-item::after {
            content: "";
            position: absolute;
            height: 3px;
            width: 100%;
            background: #e1e1e1;
            right: 50%;
            top: 20px;
            z-index: -1;
            transition: 0.4s;
        }

        .step-wizard-item:last-child::after {
            display: none;
        }

    .progress-count {
        height: 40px;
        width: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        background: #e1e1e1;
        color: #fff;
        margin-bottom: 10px;
        border: 3px solid #fff;
        transition: 0.4s;
    }

    .active-step .progress-count {
        background: #28a745;
        box-shadow: 0 0 10px rgba(40,167,69,0.3);
    }

    .active-step .step-label {
        color: #28a745;
        font-weight: bold;
    }

    .active-step::after {
        background: #28a745;
    }

    .step-label {
        font-size: 12px;
        color: #888;
    }

    .cancelled-step .progress-count {
        background: #dc3545 !important;
    }

    .cancelled-step .step-label {
        color: #dc3545 !important;
        font-weight: bold;
    }
</style>

<script>
    function updateStatus(statusString) {
        let msg = (statusString === 'Cancelled') ? "هل أنت متأكد من رغبتك في إلغاء هذا الطلب نهائياً؟" : "هل تؤكد تحديث حالة الطلب؟";
        if (confirm(msg)) {
            document.getElementById('statusValue').value = statusString;
            document.getElementById('statusForm').submit();
        }
    }
</script>